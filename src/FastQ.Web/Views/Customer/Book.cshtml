@{
    ViewBag.Title = "Customer Booking";
    var error = ViewBag.Error as string;
    var msgClass = string.IsNullOrWhiteSpace(error) ? "muted" : "muted error";
}
<form method="post" action="/Customer/Book" id="bookForm">
    <div class="card">
        <div class="eyebrow">Create Appointment</div>
        <h2 class="page-title">Follow the 5 steps to schedule.</h2>
        <p class="lead">Choose queue, service, contact method, date, time, and contact details.</p>
    </div>

    <div class="card">
        <div class="card-header">
            <div>
                <div class="eyebrow">Stepper</div>
                <h3 class="card-title">1. Select Queue &amp; Service</h3>
                <p class="card-subtitle">2. Select Contact method | 3. Select Date and Time | 4. Provide reference | 5. Contact Details</p>
            </div>
            <span class="badge accent">Required</span>
        </div>

        <div id="bookStepper" class="stepper"></div>

        <div class="stack" style="margin-top:16px;">
            <div class="card" style="padding:16px;">
                <div class="card-header">
                    <h3 class="card-title">1. Select Queue &amp; Service</h3>
                    <span class="pill">Start here</span>
                </div>
                <div class="grid-2">
                    <div class="field">
                        <label for="queueId">Queue *</label>
                        <select id="queueId" name="queueId"></select>
                    </div>
                    <div class="field">
                        <label for="serviceId">Service *</label>
                        <select id="serviceId" name="serviceId"></select>
                    </div>
                </div>
            </div>

            <div class="card" style="padding:16px;">
                <div class="card-header">
                    <h3 class="card-title">2. Select Contact method</h3>
                    <span class="pill">Method</span>
                </div>
                <div class="grid-2">
                    <div class="field">
                        <label for="contactType">Contact Type *</label>
                        <select id="contactType" name="contactType"></select>
                    </div>
                    <div class="field">
                        <label for="reference">Reference</label>
                        <select id="reference" name="refValue"></select>
                    </div>
                </div>
                <div class="field" id="meetingUrlField" style="display:none;">
                    <label for="meetingUrl">Meeting URL *</label>
                    <input type="url" id="meetingUrl" name="meetingUrl" placeholder="https://..." />
                </div>
            </div>

            <div class="card" style="padding:16px;">
                <div class="card-header">
                    <h3 class="card-title">3. Select Date and Time</h3>
                    <span class="pill">Availability</span>
                </div>
                <div class="grid-2">
                    <div class="field">
                        <label for="dateInput">Appointment Date *</label>
                        <select id="dateInput" name="appointmentDate"></select>
                    </div>
                    <div class="field">
                        <label for="startTime">Start Time *</label>
                        <select id="startTime" name="startTime"></select>
                    </div>
                </div>
            </div>

            <div class="card" style="padding:16px;">
                <div class="card-header">
                    <h3 class="card-title">4. Provide details</h3>
                    <span class="pill">Optional</span>
                </div>
                <div class="field">
                    <label for="permitNumber">Permit Number *</label>
                    <input type="text" id="permitNumber" name="permitNumber" placeholder="Permit number" />
                </div>
                <div class="field">
                    <label for="notes">Notes</label>
                    <input type="text" id="notes" name="notes" placeholder="Additional info" />
                </div>
            </div>

            <div class="card" style="padding:16px;">
                <div class="card-header">
                    <h3 class="card-title">5. Contact Details</h3>
                    <span class="pill">Required</span>
                </div>
                <div class="form-grid">
                    <div class="field">
                        <label for="email">Email Address *</label>
                        <input type="email" id="email" name="email" placeholder="you@example.com" />
                    </div>
                    <div class="field">
                        <label for="firstName">First Name *</label>
                        <input type="text" id="firstName" name="firstName" />
                    </div>
                    <div class="field">
                        <label for="lastName">Last Name *</label>
                        <input type="text" id="lastName" name="lastName" />
                    </div>
                    <div class="field">
                        <label for="phone">Mobile Number *</label>
                        <input type="text" id="phone" name="phone" placeholder="+8801..." />
                    </div>
                </div>
                <div class="row" style="margin-top:10px;">
                    <input type="checkbox" id="terms" /> <label for="terms">I agree to <a href="#">Terms and Conditions</a></label>
                </div>
            </div>

            <div class="card" style="padding:16px;">
                <div class="card-header">
                    <h3 class="card-title">Summary</h3>
                    <span class="pill">Confirm</span>
                </div>
                <div class="grid-2">
                    <div class="stat">
                        <div class="stat-label">Queue / Service</div>
                        <div class="stat-value" id="summaryQueue">-</div>
                    </div>
                    <div class="stat">
                        <div class="stat-label">Date &amp; Time</div>
                        <div class="stat-value" id="summaryTime">-</div>
                    </div>
                </div>
                <p class="muted">The queue, service, and contact options come from the same queue detail source used by provider entry forms.</p>
            </div>
        </div>

        <div class="row" style="margin-top:16px;">
            <button type="submit" class="btn secondary">Create Appointment</button>
            <button type="button" class="btn ghost" onclick="FastQBook.clear()">Clear</button>
            <span id="msg" class="@msgClass">@error</span>
        </div>
    </div>
</form>

@section Scripts {
<script>
window.FASTQ_CONTEXT = { };
var FastQBook = {
  getQueuesUrl: "/Provider/GetTransferQueues",
  getQueueDetailsUrl: "/Provider/GetQueueDetails",
  getCustomerByEmailUrl: "/Provider/GetCustomerByEmail",
  state: {
    queueId: "",
    queueName: "",
    serviceId: "",
    serviceName: "",
    contactType: "",
    contactTypeName: "",
    reference: "",
    permitNumber: "",
    appointmentDate: "",
    startTime: "",
    meetingUrl: "",
    firstName: "",
    lastName: "",
    phone: "",
    email: "",
    notes: ""
  },
  activeQueueDetails: null,
  steps: [
    { key: "queue", name: "Select Queue & Service" },
    { key: "method", name: "Select Contact method" },
    { key: "datetime", name: "Select Date and Time" },
    { key: "reference", name: "Provide details" },
    { key: "details", name: "Contact Details" }
  ],

  getJson: function (url) {
    return fetch(url, {
      method: "GET",
      credentials: "same-origin",
      headers: { "X-Requested-With": "XMLHttpRequest" }
    }).then(function (res) { return res.json(); });
  },

  setSelectOptions: function (selectElement, items, placeholder) {
    if (!selectElement) {
      return;
    }

    selectElement.innerHTML = "";

    var empty = document.createElement("option");
    empty.value = "";
    empty.textContent = placeholder || "Select";
    selectElement.appendChild(empty);

    (items || []).forEach(function (item) {
      var option = document.createElement("option");
      option.value = item.code || "";
      option.textContent = item.name || item.code || "";
      selectElement.appendChild(option);
    });
  },

  setSelectValues: function (selectElement, items, placeholder) {
    if (!selectElement) {
      return;
    }

    selectElement.innerHTML = "";

    var empty = document.createElement("option");
    empty.value = "";
    empty.textContent = placeholder || "Select";
    selectElement.appendChild(empty);

    (items || []).forEach(function (item) {
      var option = document.createElement("option");
      option.value = item.value || "";
      option.textContent = item.label || item.value || "";
      selectElement.appendChild(option);
    });
  },

  parseIsoDurationToMinutes: function (text) {
    var match = /^P(?:(\d+)D)?(?:T(?:(\d+)H)?(?:(\d+)M)?)?$/i.exec((text || "").trim());
    if (!match) {
      return 0;
    }
    var days = parseInt(match[1] || "0", 10);
    var hours = parseInt(match[2] || "0", 10);
    var minutes = parseInt(match[3] || "0", 10);
    return (((days * 24) + hours) * 60) + minutes;
  },

  normalizeScheduleWindow: function (openMinutes, closeMinutes) {
    var dayMinutes = 24 * 60;
    if (openMinutes < 0 || closeMinutes < 0) {
      return null;
    }
    if (closeMinutes <= openMinutes) {
      closeMinutes += 12 * 60;
    }
    if (closeMinutes <= openMinutes) {
      closeMinutes += 12 * 60;
    }
    if (closeMinutes > dayMinutes) {
      closeMinutes = dayMinutes;
    }
    if (closeMinutes <= openMinutes) {
      return null;
    }
    return { open: openMinutes, close: closeMinutes };
  },

  toTwoDigits: function (value) {
    return value < 10 ? ("0" + value) : String(value);
  },

  getWeekdayCode: function (dateValue) {
    var day = dateValue.getDay();
    return day === 0 ? "7" : String(day);
  },

  parseDateOnly: function (value) {
    if (!value) {
      return null;
    }
    var raw = value.toString().trim();
    if (!raw) {
      return null;
    }

    var date = new Date(raw);
    if (!isNaN(date.getTime())) {
      date.setHours(0, 0, 0, 0);
      return date;
    }

    var iso = /^(\d{4})-(\d{2})-(\d{2})/.exec(raw);
    if (iso) {
      date = new Date(parseInt(iso[1], 10), parseInt(iso[2], 10) - 1, parseInt(iso[3], 10));
      date.setHours(0, 0, 0, 0);
      return date;
    }

    var mdy = /^(\d{1,2})\/(\d{1,2})\/(\d{4})/.exec(raw);
    if (mdy) {
      date = new Date(parseInt(mdy[3], 10), parseInt(mdy[1], 10) - 1, parseInt(mdy[2], 10));
      date.setHours(0, 0, 0, 0);
      return date;
    }

    return null;
  },

  isScheduleActiveOnDate: function (schedule, dateValue) {
    if (!schedule || !dateValue) {
      return false;
    }

    var day = new Date(dateValue.getTime());
    day.setHours(0, 0, 0, 0);
    var begin = this.parseDateOnly(schedule.dateBegin || "");
    var end = this.parseDateOnly(schedule.dateEnd || "");

    if (begin && day < begin) {
      return false;
    }
    if (end && day > end) {
      return false;
    }

    var weekly = (schedule.weeklySch || "").toString();
    if (!weekly) {
      return true;
    }

    return weekly.indexOf(this.getWeekdayCode(dateValue)) >= 0;
  },

  buildDateOptions: function () {
    var options = [];
    var seen = {};
    var schedules = this.activeQueueDetails && this.activeQueueDetails.schedules ? this.activeQueueDetails.schedules : [];
    var base = new Date();
    base.setHours(0, 0, 0, 0);

    for (var i = 0; i < 31; i++) {
      var candidate = new Date(base.getTime());
      candidate.setDate(base.getDate() + i);
      var active = schedules.some(function (schedule) {
        return FastQBook.isScheduleActiveOnDate(schedule, candidate);
      });
      if (!active) {
        continue;
      }
      var value = candidate.toISOString().slice(0, 10);
      if (seen[value]) {
        continue;
      }
      seen[value] = true;
      options.push({
        value: value,
        label: value
      });
    }

    this.setSelectValues(document.getElementById("dateInput"), options, "Select date");
    if (options.length > 0) {
      document.getElementById("dateInput").value = options[0].value;
      this.state.appointmentDate = options[0].value;
    } else {
      this.state.appointmentDate = "";
    }
  },

  buildTimeOptions: function () {
    var options = [];
    var seen = {};
    var selectedDateValue = this.state.appointmentDate;
    var schedules = this.activeQueueDetails && this.activeQueueDetails.schedules ? this.activeQueueDetails.schedules : [];

    if (!selectedDateValue) {
      this.setSelectValues(document.getElementById("startTime"), [], "Select time");
      this.state.startTime = "";
      return;
    }

    var dateValue = new Date(selectedDateValue + "T00:00:00");
    schedules.forEach(function (schedule) {
      if (!FastQBook.isScheduleActiveOnDate(schedule, dateValue)) {
        return;
      }

      var openMinutes = FastQBook.parseIsoDurationToMinutes(schedule.openTime);
      var closeMinutes = FastQBook.parseIsoDurationToMinutes(schedule.closeTime);
      var intervalMinutes = FastQBook.parseIsoDurationToMinutes(schedule.intervalTime) || 30;
      var window = FastQBook.normalizeScheduleWindow(openMinutes, closeMinutes);
      if (!window) {
        return;
      }

      for (var minutes = window.open; minutes < window.close; minutes += intervalMinutes) {
        var hh = FastQBook.toTwoDigits(Math.floor(minutes / 60) % 24);
        var mm = FastQBook.toTwoDigits(minutes % 60);
        var value = hh + ":" + mm;
        if (seen[value]) {
          continue;
        }
        seen[value] = true;
        options.push({
          value: value,
          label: value
        });
      }
    });

    options.sort(function (a, b) { return a.value.localeCompare(b.value); });
    this.setSelectValues(document.getElementById("startTime"), options, "Select time");
    if (options.length > 0) {
      document.getElementById("startTime").value = options[0].value;
      this.state.startTime = options[0].value;
    } else {
      this.state.startTime = "";
    }
  },

  renderStepper: function () {
    var html = this.steps.map(function (step, idx) {
      return '<div class="step active"><div class="label">Step ' + (idx + 1) + '</div><div class="name">' + step.name + '</div></div>';
    }).join("");
    $("#bookStepper").html(html);
  },

  renderSummary: function () {
    var queueText = this.state.queueName || "Queue";
    if (this.state.serviceName) {
      queueText += " | " + this.state.serviceName;
    }
    $("#summaryQueue").text(queueText);

    var timeText = (this.state.appointmentDate || "Select date") + " | " + (this.state.startTime || "Select time");
    $("#summaryTime").text(timeText);
  },

  syncQueue: function () {
    var queueSelect = document.getElementById("queueId");
    this.state.queueId = queueSelect ? queueSelect.value : "";
    this.state.queueName = queueSelect && queueSelect.selectedIndex >= 0
      ? (queueSelect.options[queueSelect.selectedIndex].text || "")
      : "";
    this.loadQueueDetails();
  },

  syncService: function () {
    var serviceSelect = document.getElementById("serviceId");
    this.state.serviceId = serviceSelect ? serviceSelect.value : "";
    this.state.serviceName = serviceSelect && serviceSelect.selectedIndex >= 0
      ? (serviceSelect.options[serviceSelect.selectedIndex].text || "")
      : "";
    this.renderSummary();
  },

  syncContactType: function () {
    var contactSelect = document.getElementById("contactType");
    this.state.contactType = contactSelect ? contactSelect.value : "";
    this.state.contactTypeName = contactSelect && contactSelect.selectedIndex >= 0
      ? (contactSelect.options[contactSelect.selectedIndex].text || "")
      : "";
    this.syncMeetingField();
  },

  isOnlineContact: function () {
    var value = (this.state.contactType || "").toUpperCase();
    return value === "OM" || value === "VIRTUAL";
  },

  syncMeetingField: function () {
    var field = document.getElementById("meetingUrlField");
    var input = document.getElementById("meetingUrl");
    if (!field || !input) {
      return;
    }

    var isOnline = this.isOnlineContact();
    field.style.display = isOnline ? "" : "none";
    input.required = isOnline;
    if (!isOnline) {
      input.value = "";
      this.state.meetingUrl = "";
    }
  },

  syncDate: function () {
    var dateSelect = document.getElementById("dateInput");
    this.state.appointmentDate = dateSelect ? dateSelect.value : "";
    this.buildTimeOptions();
    this.renderSummary();
  },

  syncTime: function () {
    var timeSelect = document.getElementById("startTime");
    this.state.startTime = timeSelect ? timeSelect.value : "";
    this.renderSummary();
  },

  syncInfo: function () {
    this.state.reference = ($("#reference").val() || "").trim();
    this.state.firstName = ($("#firstName").val() || "").trim();
    this.state.lastName = ($("#lastName").val() || "").trim();
    this.state.phone = ($("#phone").val() || "").trim();
    this.state.email = ($("#email").val() || "").trim();
    this.state.notes = ($("#notes").val() || "").trim();
    this.state.permitNumber = ($("#permitNumber").val() || "").trim();
    this.state.queueId = ($("#queueId").val() || "").trim();
    this.state.serviceId = ($("#serviceId").val() || "").trim();
    this.state.contactType = ($("#contactType").val() || "").trim();
    this.state.appointmentDate = ($("#dateInput").val() || "").trim();
    this.state.startTime = ($("#startTime").val() || "").trim();
    this.state.meetingUrl = ($("#meetingUrl").val() || "").trim();
  },

  setCustomerFieldsDisabled: function (disabled) {
    $("#firstName, #lastName, #phone").prop("readonly", !!disabled);
    $("#email").attr("data-customer-found", disabled ? "1" : "0");
  },

  applyCustomerLookup: function (customer) {
    var wasFound = $("#email").attr("data-customer-found") === "1";
    if (customer) {
      if (customer.email) {
        $("#email").val(customer.email);
      }
      $("#firstName").val(customer.firstName || "");
      $("#lastName").val(customer.lastName || "");
      $("#phone").val(customer.phone || "");
      this.setCustomerFieldsDisabled(true);
      return;
    }

    if (wasFound) {
      $("#firstName, #lastName, #phone").val("");
    }
    this.setCustomerFieldsDisabled(false);
  },

  lookupCustomerByEmail: function () {
    var email = ($("#email").val() || "").trim();
    if (!email) {
      this.applyCustomerLookup(null);
      return Promise.resolve();
    }

    return this.getJson(this.getCustomerByEmailUrl + "?email=" + encodeURIComponent(email))
      .then(function (res) {
        if (!res || !res.ok || !res.found) {
          FastQBook.applyCustomerLookup(null);
          return;
        }
        FastQBook.applyCustomerLookup(res.data || null);
      })
      .catch(function () {
        FastQBook.applyCustomerLookup(null);
      });
  },

  hydrateProfile: function () {
    var raw = localStorage.getItem("fastq_customer_profile");
    if (!raw) {
      return;
    }
    try {
      var p = JSON.parse(raw);
      if (p.email) {
        $("#email").val(p.email);
      }
      if (p.phone) {
        $("#phone").val(p.phone);
      }
      if (p.name) {
        var parts = p.name.split(" ");
        if (parts.length > 0) {
          $("#firstName").val(parts[0]);
        }
        if (parts.length > 1) {
          $("#lastName").val(parts.slice(1).join(" "));
        }
      }
    } catch (e) { }
    this.setCustomerFieldsDisabled(false);
  },

  saveProfile: function () {
    this.syncInfo();
    var fullName = (this.state.firstName + " " + this.state.lastName).trim();
    localStorage.setItem("fastq_customer_profile", JSON.stringify({
      name: fullName,
      phone: this.state.phone || "",
      email: this.state.email || ""
    }));
  },

  loadQueues: function () {
    return this.getJson(this.getQueuesUrl)
      .then(function (res) {
        var items = res && res.ok ? (res.data || []) : [];
        FastQBook.setSelectOptions(document.getElementById("queueId"), items, "Select queue");
        if (items.length > 0) {
          document.getElementById("queueId").value = items[0].code || "";
          FastQBook.state.queueId = items[0].code || "";
          FastQBook.state.queueName = items[0].name || "";
          return FastQBook.loadQueueDetails();
        }
        FastQBook.renderSummary();
      })
      .catch(function () {
        FastQBook.setSelectOptions(document.getElementById("queueId"), [], "Select queue");
        FastQBook.setSelectOptions(document.getElementById("serviceId"), [], "Select service");
        FastQBook.setSelectOptions(document.getElementById("contactType"), [], "Select contact type");
        FastQBook.setSelectOptions(document.getElementById("reference"), [], "Select reference");
        FastQBook.setSelectValues(document.getElementById("dateInput"), [], "Select date");
        FastQBook.setSelectValues(document.getElementById("startTime"), [], "Select time");
        FastQBook.renderSummary();
      });
  },

  loadQueueDetails: function () {
    var queueId = this.state.queueId;
    if (!queueId) {
      this.activeQueueDetails = null;
      this.setSelectOptions(document.getElementById("serviceId"), [], "Select service");
      this.setSelectOptions(document.getElementById("contactType"), [], "Select contact type");
      this.setSelectOptions(document.getElementById("reference"), [], "Select reference");
      this.setSelectValues(document.getElementById("dateInput"), [], "Select date");
      this.setSelectValues(document.getElementById("startTime"), [], "Select time");
      this.renderSummary();
      return Promise.resolve();
    }

    return this.getJson(this.getQueueDetailsUrl + "?queueId=" + encodeURIComponent(queueId))
      .then(function (res) {
        var data = res && res.ok ? (res.data || null) : null;
        FastQBook.activeQueueDetails = data;
        FastQBook.setSelectOptions(document.getElementById("serviceId"), data && data.services ? data.services : [], "Select service");
        FastQBook.setSelectOptions(document.getElementById("contactType"), data && data.contactOptions ? data.contactOptions : [], "Select contact type");
        FastQBook.setSelectOptions(document.getElementById("reference"), data && data.refOptions ? data.refOptions : [], "Select reference");

        var serviceSelect = document.getElementById("serviceId");
        if (serviceSelect && serviceSelect.options.length > 1) {
          serviceSelect.selectedIndex = 1;
          FastQBook.syncService();
        } else {
          FastQBook.state.serviceId = "";
          FastQBook.state.serviceName = "";
        }

        var contactSelect = document.getElementById("contactType");
        if (contactSelect && contactSelect.options.length > 1) {
          contactSelect.selectedIndex = 1;
          FastQBook.syncContactType();
        } else {
          FastQBook.state.contactType = "";
          FastQBook.state.contactTypeName = "";
        }

        FastQBook.buildDateOptions();
        FastQBook.buildTimeOptions();
        FastQBook.renderSummary();
      })
      .catch(function () {
        FastQBook.activeQueueDetails = null;
        FastQBook.setSelectOptions(document.getElementById("serviceId"), [], "Select service");
        FastQBook.setSelectOptions(document.getElementById("contactType"), [], "Select contact type");
        FastQBook.setSelectOptions(document.getElementById("reference"), [], "Select reference");
        FastQBook.setSelectValues(document.getElementById("dateInput"), [], "Select date");
        FastQBook.setSelectValues(document.getElementById("startTime"), [], "Select time");
        FastQBook.state.serviceId = "";
        FastQBook.state.serviceName = "";
        FastQBook.state.contactType = "";
        FastQBook.state.contactTypeName = "";
        FastQBook.state.appointmentDate = "";
        FastQBook.state.startTime = "";
        FastQBook.renderSummary();
      });
  },

  validate: function () {
    this.syncInfo();
    $("#msg").removeClass("ok").removeClass("error");

    if (!this.state.queueId || !this.state.serviceId || !this.state.contactType || !this.state.appointmentDate || !this.state.startTime || !this.state.email || !this.state.phone || !this.state.firstName || !this.state.lastName || !this.state.permitNumber) {
      $("#msg").addClass("error").text("Queue, service, contact type, date, time, email, first name, last name, mobile, and permit number are required.");
      return false;
    }
    if (this.isOnlineContact() && !this.state.meetingUrl) {
      $("#msg").addClass("error").text("Meeting URL is required for online meeting.");
      return false;
    }

    if (!$("#terms").is(":checked")) {
      $("#msg").addClass("error").text("Please agree to Terms and Conditions.");
      return false;
    }

    return true;
  },

  submit: function () {
    if (!this.validate()) {
      return false;
    }

    this.saveProfile();
    $("#msg").removeClass("ok").removeClass("error").text("Creating appointment...");

    var payload = {
      queueId: this.state.queueId,
      serviceId: this.state.serviceId,
      refValue: this.state.reference,
      email: this.state.email,
      phone: this.state.phone,
      firstName: this.state.firstName,
      lastName: this.state.lastName,
      customerName: (this.state.firstName + " " + this.state.lastName).trim(),
      contactType: this.state.contactType,
      appointmentDate: this.state.appointmentDate,
      startTime: this.state.startTime,
      permitNumber: this.state.permitNumber,
      meetingUrl: this.state.meetingUrl,
      notes: this.state.notes
    };

    fetch("/Customer/Book", {
      method: "POST",
      headers: {
        "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
        "X-Requested-With": "XMLHttpRequest"
      },
      credentials: "same-origin",
      body: new URLSearchParams(payload).toString()
    })
      .then(function (res) { return res.json(); })
      .then(function (res) {
        if (!res || !res.ok) {
          $("#msg").addClass("error").text(res && res.error ? res.error : "Could not create appointment.");
          return;
        }

        $("#msg").addClass("ok").text("Appointment created.");
        var redirectUrl = res.redirectUrl || ("/Customer/Home?appointmentId=" + encodeURIComponent(res.appointmentId || ""));
        window.location.assign(redirectUrl);
      })
      .catch(function () {
        $("#msg").addClass("error").text("Could not create appointment.");
      });

    return false;
  },

  clear: function () {
    $("#firstName, #lastName, #phone, #email, #permitNumber, #notes, #meetingUrl").val("");
    $("#terms").prop("checked", false);
    this.setCustomerFieldsDisabled(false);
    this.hydrateProfile();
    this.loadQueues();
    $("#msg").removeClass("ok").removeClass("error").text("");
  },

  bindEvents: function () {
    var queue = document.getElementById("queueId");
    var service = document.getElementById("serviceId");
    var contact = document.getElementById("contactType");
    var date = document.getElementById("dateInput");
    var time = document.getElementById("startTime");

    if (queue) {
      queue.addEventListener("change", function () {
        FastQBook.syncQueue();
      });
    }
    if (service) {
      service.addEventListener("change", function () {
        FastQBook.syncService();
      });
    }
    if (contact) {
      contact.addEventListener("change", function () {
        FastQBook.syncContactType();
      });
    }
    if (date) {
      date.addEventListener("change", function () {
        FastQBook.syncDate();
      });
    }
    if (time) {
      time.addEventListener("change", function () {
        FastQBook.syncTime();
      });
    }
    $("#email").on("change blur", function () {
      FastQBook.lookupCustomerByEmail();
    });
  },

  init: function () {
    this.renderStepper();
    this.hydrateProfile();
    this.bindEvents();
    this.syncMeetingField();
    this.lookupCustomerByEmail();
    this.loadQueues();

    var form = document.getElementById("bookForm");
    if (form) {
      form.addEventListener("submit", function (event) {
        event.preventDefault();
        FastQBook.submit();
      });
    }
  }
};

$(function () { FastQBook.init(); });
</script>
}
