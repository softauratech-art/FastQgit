@using FastQ.Web.Services
@{
    Layout = null;
    var providerTodayUrl = Url.Action("Today", "Provider");


    var authsvc = new FastQ.Web.Services.AuthService();
    var isHost = authsvc.IsInRole(FastQ.Web.Helpers.Utilities.FQRole.Host);
    var isProvider = authsvc.IsInRole(FastQ.Web.Helpers.Utilities.FQRole.Provider);
    var isReporter = authsvc.IsInRole(FastQ.Web.Helpers.Utilities.FQRole.Reporter);
    var isQueueAdmin = authsvc.IsInRole(FastQ.Web.Helpers.Utilities.FQRole.QueueAdmin);
    var isSuperAdmin = authsvc.IsInRole(FastQ.Web.Helpers.Utilities.FQRole.SuperAdmin);
}
<!DOCTYPE html>
<html>
<head>
    <title>FastQ Manager</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />


    @*<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />*@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/Content/site.css">
    <style>

        .fastq-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.55);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

            .fastq-modal-backdrop.show {
                display: flex;
            }

        .fastq-modal {
            background: #ffffff;
            border-radius: 12px;
            width: min(520px, 92vw);
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.2);
            padding: 18px 20px;
        }

        .fastq-modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .fastq-modal-title {
            margin: 0;
            font-size: 18px;
            font-weight: 700;
        }

        .fastq-modal-body {
            margin-top: 10px;
            font-size: 14px;
            color: #1f2937;
            white-space: pre-wrap;
        }

        .fastq-modal-footer {
            margin-top: 16px;
            display: flex;
            justify-content: flex-end;
        }

    </style>
    @RenderSection("Head", required: false)
</head>
<body>
    <div class="layout">
        <aside class="drawer">
            <div class="brand">
                <div class="brand-top">
                    <a href="/" class="logo-container">
                        <img src="~/Content/logo-wd.png" alt="Logo" class="logo">
                    </a>
                    @*<div class="Xlogo-mark"></div>*@
                    <button class="nav-toggle" type="button" aria-label="Collapse navigation" aria-expanded="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M15 6l-6 6 6 6"></path>
                        </svg>
                    </button>
                </div>
                <div class="brand-title"><!--FastQ--></div>
                <div class="brand-sub">Queue orchestration</div>
            </div>
            <nav class="drawer-nav">
                @if (isHost || isProvider || isSuperAdmin || isQueueAdmin)
                {
                    <div class="nav-section">
                        <div class="nav-title">Overview</div>
                        <a class="nav-link active" href="@Url.Action("Index", "Home")" title="Dashboard" aria-label="Dashboard">
                            <i class="bi bi-house"></i>
                            <span class="nav-text">Dashboard</span>
                        </a>

                        <a class="nav-link" href="@Url.Action("Today", "Provider")" title="My Queues" aria-label="My Queues">
                            <i class="bi bi-person-lines-fill"></i>
                            <span class="nav-text">My Queues</span>
                        </a>

                        <a class="nav-link" href="@Url.Action("Index", "Calendar")">
                            <i class="bi bi-calendar"></i>
                            <span class="nav-text">Calendar</span>
                        </a>
                    </div>

                    <div class="nav-section">
                        <div class="nav-title">Customers</div>

                        <a class="nav-link" href="/Customer/Book">
                            <i class="bi bi-plus-circle"></i>
                            <span class="nav-text">Appointment</span>
                        </a>

                        <a class="nav-link" href="/Customer/Walkin">
                            <i class="bi bi-person-walking"></i>
                            <span class="nav-text">Walkin</span>
                        </a>
                    </div>
                }

                @if (isSuperAdmin || isQueueAdmin)
                {
                    <div class="nav-section">
                        <div class="nav-title">Admin</div>

                        <a class="nav-link" href="@Url.Action("Index", "Queue")">
                            <i class="bi bi-list-task"></i>
                            <span class="nav-text">Queues</span>
                        </a>

                        @if (isSuperAdmin)
                        {
                            <a class="nav-link" href="@Url.Action("Index", "User")">
                                <i class="bi bi-people"></i>
                                <span class="nav-text">Users</span>
                            </a>
                            <a class="nav-link" href="/">
                                <i class="bi bi-people"></i>
                                <span class="nav-text">Holidays</span>
                            </a>
                        }
                    </div>
                }

                
            <div class="nav-section">
                @if (isReporter || isSuperAdmin)
                {
                    <div class="nav-title">Reports</div>
                    <a class="nav-link" href="@Url.Action("Overview", "Reporting")">
                        <!--/Reporting/Overview-->
                        <i class="bi bi-bar-chart-line"></i>
                        <span class="nav-text">Reports</span>
                    </a>
                }
                    <a class="nav-link" href="~/Logout.aspx">
                        <i class="bi bi-box-arrow-right"></i>
                        <span class="nav-text">Logout</span>
                    </a>
            </div>
              
                @*<div class="nav-section">
                <a class="nav-link" href="/Admin/Dashboard">
                    <i class="bi bi-gear"></i>
                    <span class="nav-text">Settings</span>
                </a>
                <a class="nav-link" href="/">
                    <i class="bi bi-search"></i>
                    <span class="nav-text">Search</span>
                </a>
                <a class="nav-link" href="/">
                    <i class="bi bi-question-circle"></i>
                    <span class="nav-text">Help</span>
                </a>

                <a class="nav-link" href="/Customer/Login">
                    <i class="bi bi-person"></i>
                    <span class="nav-text"></span>
                </a>*@

            </nav>
            <div class="drawer-footer">
                <div class="status-card">
                    <div class="status-title">System Health</div>
                    <div style="display:flex; align-items:center; justify-content:space-between;">
                        <span class="pill">Online</span>
                        <span class="muted"></span>
                    </div>
                </div>
            </div>
        </aside>

        <div class="main-area">
            <header class="topbar">
                @RenderSection("PageHeader", required: false)
                <div class="user-chip">
                    @*@(new FastQ.Web.Services.AuthService().GetLoggedInWindowsUser())*@
                    @User.Identity.Name
                </div>
            </header>

            <main class="page">
                @RenderBody()
            </main>
        </div>
    </div>

    <div id="fastq_toast" class="toast"></div>
    <div id="fastq_error_modal" class="fastq-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="fastqErrorTitle">
        <div class="fastq-modal">
            <div class="fastq-modal-header">
                <h5 class="fastq-modal-title" id="fastqErrorTitle">Error</h5>
                <button class="btn small ghost" type="button" data-fastq-error-close="true">Close</button>
            </div>
            <div class="fastq-modal-body" id="fastqErrorBody"></div>
            <div class="fastq-modal-footer">
                <button class="btn ghost" type="button" data-fastq-error-close="true">OK</button>
            </div>
        </div>
    </div>

    <!-- SignalR client -->
    @*<script src="~/Scripts/jquery-1.6.4.min.js"></script>*@
    <script src="~/Scripts/jquery-3.7.1.js"></script>
    <script src="~/Scripts/jquery.signalR-2.4.3.min.js"></script>
    <script src="~/signalr/hubs"></script>
    <script src="@Url.Content("~/Scripts/fastq.live.js")"></script>
    @RenderSection("Scripts", required: false)
    <script>
        (function () {
            var toggle = document.querySelector(".nav-toggle");
            if (!toggle) {
                return;
            }
            toggle.addEventListener("click", function () {
                var collapsed = document.body.classList.toggle("nav-collapsed");
                toggle.setAttribute("aria-expanded", (!collapsed).toString());
                toggle.setAttribute("aria-label", collapsed ? "Expand navigation" : "Collapse navigation");
            });

            //// Highlight the active link based on URL
            //const currentPath = location.pathname;
            //const navLinks = document.querySelectorAll('.nav-link');
            //navLinks.forEach(l => {
            //    l.classList.remove('active');
            //    if (l.pathname === currentPath) {
            //        l.classList.add('active');
            //    }
            //});

            // Get all navigation links
            const navLinks = document.querySelectorAll('.nav-link');
            const currentPath = window.location.pathname;
            navLinks.forEach(link => {
                link.classList.remove('active');
                const linkPath = new URL(link.href).pathname;
                if (currentPath.startsWith(linkPath) && linkPath !== "/") {
                    link.classList.add('active');
                }
                // Special handling for the root path if needed, to avoid matching everything
                if (linkPath === "/" && currentPath === "/") {
                    link.classList.add('active');
                }
            });
        })();

        // signalR related ???
        (function () {
            var modal = document.getElementById("fastq_error_modal");
            var titleEl = document.getElementById("fastqErrorTitle");
            var bodyEl = document.getElementById("fastqErrorBody");

            function closeErrorModal() {
                if (modal) {
                    modal.classList.remove("show");
                }
            }

            function showErrorModal(message, title) {
                if (!modal || !bodyEl) {
                    return;
                }
                if (titleEl) {
                    titleEl.textContent = title || "Error";
                }
                bodyEl.textContent = (message || "An unexpected error occurred.").toString();
                modal.classList.add("show");
            }

            document.querySelectorAll("[data-fastq-error-close]").forEach(function (btn) {
                btn.addEventListener("click", closeErrorModal);
            });

            if (modal) {
                modal.addEventListener("click", function (evt) {
                    if (evt.target === modal) {
                        closeErrorModal();
                    }
                });
            }

            window.FastQShowError = showErrorModal;

            window.alert = function (message) {
                showErrorModal(message, "Error");
            };

            window.addEventListener("error", function (evt) {
                if (evt && evt.message) {
                    showErrorModal(evt.message, "Error");
                }
            });

            window.addEventListener("unhandledrejection", function (evt) {
                var reason = evt && evt.reason ? evt.reason : "Unhandled promise rejection.";
                var text = reason && reason.message ? reason.message : reason;
                showErrorModal(text, "Error");
            });
        })();
    </script>
</body>
</html>
