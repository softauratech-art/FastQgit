          notes: document.getElementById("addApptNotes") ? document.getElementById("addApptNotes").value : ""
        };

        var apptRefMeta = getReferenceFieldMeta(payload.refValue);
        var apptHasReferenceValue = apptRefMeta.useAddressFields
          ? !!(payload.streetNumber && payload.streetName)
          : !!payload.permitNumber;
        if (!payload.queueId || !payload.refValue || !apptHasReferenceValue || !payload.email || !payload.customerName || !payload.phone || !payload.appointmentDate || !payload.startTime) {
          showModalFeedback("addAppointmentModal", "Queue, reference, reference value, email, first name, last name, phone, date, and time are required.", true);
