      var url = new URL(window.location.href);
      url.searchParams.set("start", startValue);
      url.searchParams.set("end", endValue);
      window.location.assign(url.toString());
    }

    function clampRange(startInput, endInput) {
      if (!startInput || !endInput || !startInput.value || !endInput.value) {
        return;
      }

      if (endInput.value < startInput.value) {
        endInput.value = startInput.value;
      }
    }

    function applyTableFilters(container) {
      if (!container) {
        return;
      }

      var customerInput = container.querySelector('[data-filter="customer"]');
      var statusInput = container.querySelector('[data-filter="status"]');
      var startInput = container.querySelector('[data-filter="start"]');
      var endInput = container.querySelector('[data-filter="end"]');
      var customerValue = (customerInput && customerInput.value ? customerInput.value : "").toLowerCase().trim();
      var statusValue = (statusInput && statusInput.value ? statusInput.value : "").toLowerCase();
      var startValue = startInput && startInput.value ? startInput.value : "";
      var endValue = endInput && endInput.value ? endInput.value : "";
      var tables = container.parentElement
        ? Array.prototype.slice.call(container.parentElement.querySelectorAll("table"))
        : [];
      if (!tables.length) {
        tables = Array.prototype.slice.call(document.querySelectorAll(".table-card table"));
      }
      if (!tables.length) {
        return;
      }

      clampRange(startInput, endInput);
      startValue = startInput && startInput.value ? startInput.value : "";
      endValue = endInput && endInput.value ? endInput.value : "";

      tables.forEach(function (table) {
        table.querySelectorAll("tbody tr.accordion-toggle").forEach(function (row) {
          var rowStatus = (row.getAttribute("data-status") || "").toLowerCase();
          var rowDate = row.getAttribute("data-date") || "";
          var rowCustomer = (row.getAttribute("data-customer") || "").toLowerCase();
          var match = true;

          if (customerValue && rowCustomer.indexOf(customerValue) === -1) {
            match = false;
          }
          if (statusValue && statusValue !== "all" && rowStatus !== statusValue) {
            match = false;
          }
          if (startValue && rowDate < startValue) {
            match = false;
          }
          if (endValue && rowDate > endValue) {
            match = false;
          }

          row.classList.toggle("is-hidden", !match);
          var apptId = row.getAttribute("data-appointment-id");
          if (apptId) {
            document.querySelectorAll('.row-actions[data-appointment-id="' + apptId + '"]').forEach(function (detail) {
              detail.classList.toggle("is-hidden", !match);
              if (!match) {
                detail.classList.remove("is-open");
              }
            });
          }
        });

        var visibleRows = Array.prototype.filter.call(
          table.querySelectorAll("tbody tr.accordion-toggle"),
          function (row) { return !row.classList.contains("is-hidden"); }
        );
        var emptyRow = table.querySelector("tbody tr.table-empty");
        if (emptyRow) {
          emptyRow.classList.toggle("is-hidden", visibleRows.length > 0);
        }
      });
    }

    function bindAccordionRows() {
      document.querySelectorAll(".accordion-toggle").forEach(function (row) {
        if (row.getAttribute("data-bound-accordion") === "1") {
          return;
        }
        row.setAttribute("data-bound-accordion", "1");
        row.addEventListener("click", function () {
          var targetId = row.getAttribute("data-target");
          if (!targetId) {
            return;
          }
          document.querySelectorAll(".row-actions").forEach(function (detail) {
            if (detail.id !== targetId) {
              detail.classList.remove("is-open");
            }
          });
          var target = document.getElementById(targetId);
          if (target) {
            target.classList.toggle("is-open");
          }
        });
      });
    }

    document.querySelectorAll(".table-filters").forEach(function (container) {
      container.querySelectorAll(".filter-input").forEach(function (input) {
        input.addEventListener("change", function () { applyTableFilters(container); });
        input.addEventListener("input", function () { applyTableFilters(container); });
        if (input.getAttribute("data-filter") === "start" || input.getAttribute("data-filter") === "end") {
          input.addEventListener("change", function () {
            var startInput = container.querySelector('[data-filter="start"]');
            var endInput = container.querySelector('[data-filter="end"]');
            if (startInput && endInput) {
              clampRange(startInput, endInput);
              updateRangeAndReload(startInput.value, endInput.value);
            }
          });
        }
      });

      container.querySelectorAll("[data-date-shift]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var target = btn.getAttribute("data-date-target");
          var dateInput = target ? container.querySelector('[data-filter="' + target + '"]') : null;
          if (!dateInput || !dateInput.value) {
            return;
          }
          var parts = dateInput.value.split("-");
          if (parts.length !== 3) {
            return;
          }
          var year = parseInt(parts[0], 10);
          var month = parseInt(parts[1], 10);
          var day = parseInt(parts[2], 10);
          if (!year || !month || !day) {
            return;
          }
          var base = new Date(Date.UTC(year, month - 1, day));
          var shift = parseInt(btn.getAttribute("data-date-shift") || "0", 10);
          if (!shift) {
            return;
          }
          base.setUTCDate(base.getUTCDate() + shift);
          var nextValue = base.toISOString().slice(0, 10);
          dateInput.value = nextValue;
          var startInput = container.querySelector('[data-filter="start"]');
          var endInput = container.querySelector('[data-filter="end"]');
          if (startInput && endInput) {
            clampRange(startInput, endInput);
            updateRangeAndReload(startInput.value, endInput.value);
          }
        });
      });

      var reset = container.querySelector("[data-filter-reset]");
      if (reset) {
        reset.addEventListener("click", function () {
          var customerInput = container.querySelector('[data-filter="customer"]');
          var statusInput = container.querySelector('[data-filter="status"]');
          var startInput = container.querySelector('[data-filter="start"]');
          var endInput = container.querySelector('[data-filter="end"]');
          if (customerInput) {
            customerInput.value = "";
          }
          if (statusInput) {
            statusInput.value = "all";
          }
          if (startInput) {
            startInput.value = "@defaultDate";
          }
          if (endInput) {
            endInput.value = "@endDate";
          }
          applyTableFilters(container);
        });
      }

      applyTableFilters(container);
    });

    function normalizeStatus(text) {
      return (text || "").toString().trim().toLowerCase();
    }

    function getStatusForAppointment(id) {
      var row = document.querySelector('.accordion-toggle[data-appointment-id="' + id + '"]');
      return row ? normalizeStatus(row.getAttribute("data-status")) : "";
    }

    function hasQueuePermission(actionName, queueId) {
      var access = serviceAccess || {};
      var numericQueueId = parseInt(queueId || "0", 10);
      var providerQueueIds = Array.isArray(access.ProviderQueueIds) ? access.ProviderQueueIds : [];
      var queueAdminQueueIds = Array.isArray(access.QueueAdminQueueIds) ? access.QueueAdminQueueIds : [];
      var providerHasQueue = providerQueueIds.indexOf(numericQueueId) >= 0;
      var queueAdminHasQueue = queueAdminQueueIds.indexOf(numericQueueId) >= 0;

      if (access.IsAdmin) {
        return true;
      }
      if (actionName === "arrive") {
        return !!access.IsHost || !!access.IsProvider || queueAdminHasQueue;
      }
      if (actionName === "transfer") {
        return !!access.IsHost || !!access.IsProvider || queueAdminHasQueue;
      }
      if (actionName === "remove") {
        return !!access.IsHost || !!access.IsProvider || queueAdminHasQueue;
      }
      if (actionName === "info") {
        return !!access.IsHost || !!access.IsProvider || queueAdminHasQueue;
      }
      if (actionName === "begin" || actionName === "end") {
        return providerHasQueue || queueAdminHasQueue;
      }
      return false;
    }

    function canAction(status, actionName, queueId) {
      if (!hasQueuePermission(actionName, queueId)) {
        return false;
      }
      var finished = status === "completed" || status === "cancelled" || status === "closedbysystem" || status === "transferredout";
      if (finished) {
        return false;
      }
      if (actionName === "arrive") {
        return status === "scheduled";
      }
      if (actionName === "begin") {
        return status === "arrived" || status === "scheduled";
      }
      if (actionName === "end") {
        return status === "inservice";
      }
      if (actionName === "remove") {
        return !finished;
      }
      return true;
    }

    function compareSortValues(a, b, kind, direction) {
      var left = (a || "").toString().trim().toLowerCase();
      var right = (b || "").toString().trim().toLowerCase();
      if (kind === "time") {
        var parseClock = function (text) {
          var match = /^(\d{1,2}):(\d{2})(?:\s*([ap]m))?$/i.exec((text || "").trim());
          if (!match) return NaN;
          var hour = parseInt(match[1], 10);
          var minute = parseInt(match[2], 10);
          var meridiem = (match[3] || "").toLowerCase();
          if (meridiem === "pm" && hour < 12) hour += 12;
          if (meridiem === "am" && hour === 12) hour = 0;
          return (hour * 60) + minute;
        };
        var leftTime = parseClock(left);
        var rightTime = parseClock(right);
        if (!isNaN(leftTime) && !isNaN(rightTime)) {
          return direction * (leftTime - rightTime);
        }
      }

      if (left < right) return -1 * direction;
      if (left > right) return 1 * direction;
      return 0;
    }

    function sortProviderTable(table, columnIndex, kind, direction) {
      if (!table || !table.tBodies || table.tBodies.length === 0) {
        return;
      }

      var tbody = table.tBodies[0];
      var rows = Array.prototype.slice.call(tbody.querySelectorAll("tr.accordion-toggle"));
      var pairs = rows.map(function (summary) {
        var targetId = summary.getAttribute("data-target");
        var detail = targetId ? document.getElementById(targetId) : null;
        return {
          summary: summary,
          detail: detail,
          value: summary.children.length > columnIndex ? summary.children[columnIndex].textContent : ""
        };
      });

      pairs.sort(function (left, right) {
        return compareSortValues(left.value, right.value, kind, direction);
      });

      var empty = tbody.querySelector(".table-empty");
      pairs.forEach(function (pair) {
        tbody.appendChild(pair.summary);
        if (pair.detail) {
          tbody.appendChild(pair.detail);
        }
      });
      if (empty) {
        tbody.appendChild(empty);
      }
    }

    function bindTodaySorting() {
      document.querySelectorAll(".table-card table").forEach(function (table) {
        var headers = table.querySelectorAll("thead th[data-sort-key]");
        headers.forEach(function (header, index) {
          if (header.getAttribute("data-bound-sort") === "1") {
            return;
          }
          header.setAttribute("data-bound-sort", "1");
          header.style.cursor = "pointer";
          header.setAttribute("title", "Sort");
          header.addEventListener("click", function () {
            var key = (header.getAttribute("data-sort-key") || "text").toLowerCase();
            var nextDirection = header.getAttribute("data-sort-direction") === "asc" ? -1 : 1;
            table.querySelectorAll("thead th[data-sort-key]").forEach(function (th) {
              th.removeAttribute("data-sort-direction");
            });
            header.setAttribute("data-sort-direction", nextDirection === 1 ? "asc" : "desc");
            sortProviderTable(table, index, key, nextDirection);
          });
        });
      });
    }

    function bindProviderActionButtons() {
      document.querySelectorAll("[data-provider-action]").forEach(function (btn) {
        var action = (btn.getAttribute("data-action") || "").toLowerCase();
        var appointmentId = btn.getAttribute("data-appointment-id");
        var queueId = btn.getAttribute("data-queue-id");
        var status = appointmentId ? getStatusForAppointment(appointmentId) : "";
        btn.disabled = !canAction(status, action, queueId);

        if (btn.getAttribute("data-bound-provider-action") === "1") {
          return;
        }
        btn.setAttribute("data-bound-provider-action", "1");
        btn.addEventListener("click", function (event) {
        event.preventDefault();
        event.stopPropagation();

        var appointmentId = btn.getAttribute("data-appointment-id");
        var action = (btn.getAttribute("data-action") || "").toLowerCase();
        var srcType = (btn.getAttribute("data-src-type") || "").toUpperCase();
        var queueId = btn.getAttribute("data-queue-id");
        if (!appointmentId || !action) {
          return;
        }
        if (!srcType) {
          var sourceRow = document.querySelector('.accordion-toggle[data-appointment-id="' + appointmentId + '"]');
          if (sourceRow) {
            srcType = (sourceRow.getAttribute("data-src-type") || "").toUpperCase();
          }
        }
        if (!srcType) {
          srcType = "A";
        }

        var status = getStatusForAppointment(appointmentId);
        if (!canAction(status, action, queueId)) {
          window.alert("Action not allowed for the current status.");
          return;
        }

        if (action === "transfer") {
          openRouteModal("transfer", appointmentId, srcType);
          return;
        }

        if (action === "end") {
          openEndServiceModal(appointmentId, srcType);
          return;
        }

        if (action === "remove") {
          openCancelServiceModal(appointmentId, srcType);
          return;
        }

        postForm(providerActionUrl, { action: action, appointmentId: appointmentId, srcType: srcType })
          .then(function (res) {
            if (!res || !res.ok) {
              window.alert(res && res.error ? res.error : "Action failed.");
              return;
            }
            queueLiveSync();
          });
        });
      });
    }

    function lockAppointment(appointmentId) {
      document.querySelectorAll('[data-appointment-id="' + appointmentId + '"]').forEach(function (el) {
        el.classList.add("locked");
      });
    }

    function getStatusTextForDisplay(normalizedStatus) {
      if (normalizedStatus === "arrived") return "ARRIVED";
      if (normalizedStatus === "inservice") return "IN PROGRESS";
      if (normalizedStatus === "completed") return "DONE";
      if (normalizedStatus === "cancelled") return "CANCELLED";
      if (normalizedStatus === "scheduled") return "SCHEDULED";
      if (normalizedStatus === "transferredout") return "TRANSFERRED";
      return (normalizedStatus || "").toUpperCase();
    }

    function applyLiveStatus(appointmentId, status) {
      var row = document.querySelector('.accordion-toggle[data-appointment-id="' + appointmentId + '"]');
      if (!row) {
        return;
      }

      var normalized = normalizeStatus(status);
      row.setAttribute("data-status", status || "");
      var statusCell = row.children.length > 5 ? row.children[5] : null;
      if (statusCell) {
        statusCell.textContent = getStatusTextForDisplay(normalized);
        statusCell.classList.toggle("error", normalized === "cancelled");
      }
    }

    var liveSyncTimer = null;
    var liveSyncInFlight = false;
    function getRowKey(row) {
      if (!row) {
        return "";
      }
      var srcType = row.getAttribute("data-src-type") || "";
      var appointmentId = row.getAttribute("data-appointment-id") || "";
      return srcType + ":" + appointmentId;
    }

    function findDetailRowByTarget(tableBody, targetId) {
      if (!tableBody || !targetId) {
        return null;
      }
      return tableBody.querySelector('tr[id="' + targetId + '"]');
    }

    function collectRowPairs(tableBody) {
      var pairs = [];
      if (!tableBody) {
        return pairs;
      }

      tableBody.querySelectorAll("tr.accordion-toggle").forEach(function (summaryRow) {
        var targetId = summaryRow.getAttribute("data-target") || "";
        var detailRow = findDetailRowByTarget(tableBody, targetId);
        if (!detailRow) {
          return;
        }
        pairs.push({
          key: getRowKey(summaryRow),
          summary: summaryRow,
          detail: detailRow
        });
      });

      return pairs;
    }

    function applyIncomingRows(currentBody, incomingBody) {
      if (!currentBody || !incomingBody) {
        return;
      }

      var incomingPairs = collectRowPairs(incomingBody);
      var incomingKeys = {};
      incomingPairs.forEach(function (pair) {
        incomingKeys[pair.key] = true;
      });

      // Remove rows that no longer exist in server response.
      collectRowPairs(currentBody).forEach(function (pair) {
        if (incomingKeys[pair.key]) {
          return;
        }
        pair.summary.parentNode.removeChild(pair.summary);
        pair.detail.parentNode.removeChild(pair.detail);
      });

      var emptyRow = currentBody.querySelector("tr.table-empty");
      incomingPairs.forEach(function (pair) {
        var keyParts = pair.key.split(":");
        var srcType = keyParts[0] || "";
        var appointmentId = keyParts.length > 1 ? keyParts[1] : "";
        var selector = 'tr.accordion-toggle[data-appointment-id="' + appointmentId + '"][data-src-type="' + srcType + '"]';
        var currentSummary = currentBody.querySelector(selector);
        var incomingSummary = document.importNode(pair.summary, true);
        var incomingDetail = document.importNode(pair.detail, true);

        if (currentSummary) {
          var currentTargetId = currentSummary.getAttribute("data-target") || "";
          var currentDetail = findDetailRowByTarget(currentBody, currentTargetId);
          currentBody.insertBefore(incomingSummary, currentSummary);
          currentSummary.parentNode.removeChild(currentSummary);
          if (currentDetail) {
            currentBody.insertBefore(incomingDetail, currentDetail);
            currentDetail.parentNode.removeChild(currentDetail);
          } else if (emptyRow) {
            currentBody.insertBefore(incomingDetail, emptyRow);
          } else {
            currentBody.appendChild(incomingDetail);
          }
          return;
        }

        if (emptyRow) {
          currentBody.insertBefore(incomingSummary, emptyRow);
          currentBody.insertBefore(incomingDetail, emptyRow);
        } else {
          currentBody.appendChild(incomingSummary);
          currentBody.appendChild(incomingDetail);
        }
      });
    }

    function syncTablesFromServer() {
      if (liveSyncInFlight) {
        return;
      }

      liveSyncInFlight = true;
      var openRowIds = Array.prototype.map.call(
        document.querySelectorAll(".row-actions.is-open"),
        function (el) { return el.id; }
      );
      var lockedIds = Array.prototype.map.call(
        document.querySelectorAll(".accordion-toggle.locked"),
        function (el) { return el.getAttribute("data-appointment-id") || ""; }
      ).filter(function (id) { return !!id; });

      fetch(window.location.pathname + window.location.search, {
        method: "GET",
        credentials: "same-origin"
      })
        .then(function (res) { return res.text(); })
        .then(function (html) {
          var parser = new DOMParser();
          var nextDoc = parser.parseFromString(html, "text/html");
          var currentBodies = document.querySelectorAll(".table-card table tbody");
          var nextBodies = nextDoc.querySelectorAll(".table-card table tbody");
          var count = Math.min(currentBodies.length, nextBodies.length);

          for (var i = 0; i < count; i++) {
            applyIncomingRows(currentBodies[i], nextBodies[i]);
          }

          bindAccordionRows();
          bindProviderActionButtons();
          bindMeetingLinks();

          openRowIds.forEach(function (id) {
            var detail = document.getElementById(id);
            if (detail) {
              detail.classList.add("is-open");
            }
          });
          lockedIds.forEach(function (id) {
            lockAppointment(id);
          });

          document.querySelectorAll(".table-filters").forEach(function (container) {
            applyTableFilters(container);
          });
          var globalSearch = document.getElementById("todayGlobalSearch");
          if (globalSearch && globalSearch.value) {
            globalSearch.dispatchEvent(new Event("input"));
          }
          liveSyncInFlight = false;
        })
        .catch(function () {
          liveSyncInFlight = false;
        });
    }

    function queueLiveSync() {
      if (liveSyncTimer) {
        return;
      }
      liveSyncTimer = setTimeout(function () {
        liveSyncTimer = null;
        syncTablesFromServer();
      }, 300);
    }

    function formatNotificationTime(date) {
      if (!date) {
        return "";
      }
      return date.toLocaleString([], {
        month: "short",
        day: "numeric",
        hour: "numeric",
        minute: "2-digit"
      });
    }

    function escapeHtml(text) {
      return (text || "").toString()
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function renderNotifications() {
      var body = document.getElementById("todayNotificationsBody");
      var count = document.getElementById("todayNotificationsCount");
      if (count) {
        count.textContent = String(todayNotificationUnreadCount);
        count.classList.toggle("show", todayNotificationUnreadCount > 0);
      }
      if (!body) {
        return;
      }
      if (!todayNotifications.length) {
        body.innerHTML = '<div class="notif-empty">No notifications yet.</div>';
        return;
      }
      body.innerHTML = todayNotifications.map(function (item) {
        return '<div class="notif-item">'
          + '<p class="notif-message">' + escapeHtml(item.message || "") + '</p>'
          + '<div class="notif-time">' + escapeHtml(item.timeText || "") + '</div>'
          + '</div>';
      }).join("");
    }

    function markNotificationsRead() {
      todayNotificationUnreadCount = 0;
      renderNotifications();
    }

    function toggleNotifications(forceOpen) {
      var panel = document.getElementById("todayNotificationsPanel");
      var button = document.getElementById("todayNotificationsButton");
      if (!panel || !button) {
        return;
      }
      var nextOpen = typeof forceOpen === "boolean" ? forceOpen : !panel.classList.contains("show");
      panel.classList.toggle("show", nextOpen);
      button.setAttribute("aria-expanded", nextOpen ? "true" : "false");
      if (nextOpen) {
        markNotificationsRead();
      }
    }

    function addNotification(message) {
      if (!message) {
        return;
      }
      todayNotifications.unshift({
        message: message,
        timeText: formatNotificationTime(new Date())
      });
      if (todayNotifications.length > maxNotificationItems) {
        todayNotifications.length = maxNotificationItems;
      }
      var panel = document.getElementById("todayNotificationsPanel");
      if (!panel || !panel.classList.contains("show")) {
        todayNotificationUnreadCount += 1;
      }
      renderNotifications();
    }

    window.onFastQQueueUpdated = function () {
      queueLiveSync();
    };

    window.onFastQAppointmentUpdated = function (appointmentId, status, providerId) {
      console.log("SignalR appointmentUpdated:", appointmentId, status, providerId, currentProviderId);
      var normalized = (status || "").toString().toLowerCase();
      var isSelf = (providerId || "").toString().toLowerCase() === (currentProviderId || "").toString().toLowerCase();
      var hasRow = !!document.querySelector('.accordion-toggle[data-appointment-id="' + appointmentId + '"]');
      applyLiveStatus(appointmentId, status);
      if (normalized === "inservice" || normalized === "completed" || normalized === "cancelled" || normalized === "transferredout" || normalized === "scheduled" || normalized === "arrived") {
        if (!isSelf) {
          lockAppointment(appointmentId);
          document.querySelectorAll(".table-filters").forEach(function (container) {
            applyTableFilters(container);
          });
        }
      }
      // New rows (e.g. transfer target) may not exist locally yet.
      if (!hasRow && (normalized === "scheduled" || normalized === "arrived")) {
        queueLiveSync();
      }
    };

    window.onFastQNotify = function (message) {
      addNotification(message);
    };

    var todayNotificationsButton = document.getElementById("todayNotificationsButton");
    if (todayNotificationsButton) {
      todayNotificationsButton.addEventListener("click", function (event) {
        event.stopPropagation();
        toggleNotifications();
      });
    }

    var todayNotificationsClear = document.getElementById("todayNotificationsClear");
    if (todayNotificationsClear) {
      todayNotificationsClear.addEventListener("click", function (event) {
        event.preventDefault();
        todayNotifications = [];
        todayNotificationUnreadCount = 0;
        renderNotifications();
      });
    }

    document.addEventListener("click", function (event) {
      var panel = document.getElementById("todayNotificationsPanel");
      var button = document.getElementById("todayNotificationsButton");
      if (!panel || !button) {
        return;
      }
      if (panel.contains(event.target) || button.contains(event.target)) {
        return;
      }
      toggleNotifications(false);
    });

    document.querySelectorAll("[data-modal-close]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        closeModal(btn.getAttribute("data-modal-close"));
      });
    });

    document.querySelectorAll("[data-end-choice]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var choice = btn.getAttribute("data-end-choice");
        var srcIdInput = document.getElementById("endServiceSrcId");
        var srcTypeInput = document.getElementById("endServiceSrcType");
        var completionNotesInput = document.getElementById("endServiceCompletionNotes");
        var appointmentId = srcIdInput ? srcIdInput.value : "";
        var srcType = srcTypeInput ? srcTypeInput.value : "";
        var completionNotes = completionNotesInput ? completionNotesInput.value : "";
        if (!appointmentId || !srcType) {
          closeModal("endServiceModal");
          return;
        }

        if (choice === "end-add") {
          closeModal("endServiceModal");
          openRouteModal("end-add", appointmentId, srcType, completionNotes);
          return;
