@section Scripts {
    <script>
  (function () {
    var providerActionUrl = "@Url.Action("ProviderAction", "Provider")";
    var addAppointmentUrl = "@Url.Action("AddAppointment", "Provider")";
    var addWalkinUrl = "@Url.Action("AddWalkin", "Provider")";
    var transferUrl = "@Url.Action("TransferAppointment", "Provider")";
    var endServiceUrl = "@Url.Action("EndService", "Provider")";
    var saveServiceInfoUrl = "@Url.Action("SaveServiceInfo", "Provider")";
    var getTransferQueuesUrl = "@Url.Action("GetTransferQueues", "Provider")";
    var getTransferServicesUrl = "@Url.Action("GetTransferServices", "Provider")";
    var getQueueDetailsUrl = "@Url.Action("GetQueueDetails", "Provider")";
    var currentProviderId = "@(ViewBag.ProviderId as string ?? string.Empty)";
    var activeRouteQueueDetails = null;

    function postForm(url, data) {
      return fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
        credentials: "same-origin",
        body: new URLSearchParams(data).toString()
      }).then(function (r) { return r.json(); });
    }

    function getJson(url) {
      return fetch(url, {
        method: "GET",
        credentials: "same-origin"
      }).then(function (r) { return r.json(); });
    }

    function setSelectOptions(selectElement, items, placeholderText) {
      if (!selectElement) {
        return;
      }

      selectElement.innerHTML = "";
      var placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = placeholderText;
      selectElement.appendChild(placeholder);

      (items || []).forEach(function (item) {
        var option = document.createElement("option");
        option.value = item.code || "";
        option.textContent = item.name || item.code || "";
        selectElement.appendChild(option);
      });
    }

    function populateEntryModalOptions(prefix, details) {
      setSelectOptions(document.getElementById(prefix + "ServiceId"), details && details.services ? details.services : [], "Select service");
      setSelectOptions(document.getElementById(prefix + "ContactType"), details && details.contactOptions ? details.contactOptions : [], "Select contact type");
      setSelectOptions(document.getElementById(prefix + "RefValue"), details && details.refOptions ? details.refOptions : [], "Select reference");
    }

    function loadEntryQueueDetails(prefix, queueCode) {
      if (!queueCode) {
        populateEntryModalOptions(prefix, null);
        return Promise.resolve();
      }

      return getJson(getQueueDetailsUrl + "?queueId=" + encodeURIComponent(queueCode))
        .then(function (res) {
          populateEntryModalOptions(prefix, res && res.ok ? res.data : null);
        })
        .catch(function () {
          populateEntryModalOptions(prefix, null);
        });
    }

    function loadEntryQueues(prefix) {
      var queueSelect = document.getElementById(prefix + "QueueId");
      if (!queueSelect) {
        return Promise.resolve();
      }

      return getJson(getTransferQueuesUrl)
        .then(function (res) {
          setSelectOptions(queueSelect, res && res.ok ? res.data : [], "Select queue");
        })
        .catch(function () {
          setSelectOptions(queueSelect, [], "Select queue");
        });
    }

    function clearAddEntryModal(prefix) {
      var fields = [
        "QueueId", "ServiceId", "ContactType", "RefValue",
        "CustomerName", "Phone", "MeetingUrl", "Notes"
      ];

      fields.forEach(function (suffix) {
        var input = document.getElementById(prefix + suffix);
        if (input) {
          input.value = "";
        }
      });

      var dateInput = document.getElementById(prefix + "Date");
      if (dateInput) {
        dateInput.value = "@defaultDate";
      }

      var timeInput = document.getElementById(prefix + "Time");
      if (timeInput) {
        timeInput.value = "09:00";
      }

      populateEntryModalOptions(prefix, null);
    }

    function parseIsoDurationToMinutes(text) {
      var match = /^P(?:(\d+)D)?(?:T(?:(\d+)H)?(?:(\d+)M)?)?$/i.exec((text || "").trim());
      if (!match) {
        return 0;
      }
      var days = parseInt(match[1] || "0", 10);
      var hours = parseInt(match[2] || "0", 10);
      var minutes = parseInt(match[3] || "0", 10);
      return (((days * 24) + hours) * 60) + minutes;
    }

    function getWeekdayCode(dateValue) {
      var day = dateValue.getDay();
      return day === 0 ? "7" : String(day);
    }

    function isScheduleActiveOnDate(schedule, dateValue) {
      if (!schedule || !dateValue) {
        return false;
      }
      var dateText = dateValue.toISOString().slice(0, 10);
      var begin = (schedule.dateBegin || "").slice(0, 10);
      var end = (schedule.dateEnd || "").slice(0, 10);
      if (begin && dateText < begin) {
        return false;
      }
      if (end && dateText > end) {
        return false;
      }
      var weekly = (schedule.weeklySch || "").toString();
      if (!weekly) {
        return true;
      }
      return weekly.indexOf(getWeekdayCode(dateValue)) >= 0;
    }

    function buildScheduleDateOptions(details, selectedDateValue) {
      var options = [];
      var schedules = details && details.schedules ? details.schedules : [];
      var seen = {};
      var base = new Date();
      base.setHours(0, 0, 0, 0);
      for (var i = 0; i < 31; i++) {
        var candidate = new Date(base.getTime());
        candidate.setDate(base.getDate() + i);
        var active = schedules.some(function (schedule) {
          return isScheduleActiveOnDate(schedule, candidate);
        });
        if (!active) {
          continue;
        }
        var value = candidate.toISOString().slice(0, 10);
        if (seen[value]) {
          continue;
        }
        seen[value] = true;
        options.push({
          value: value,
          label: formatRouteDateLabel(candidate)
        });
      }

      var select = document.getElementById("routeTargetDate");
      setSelectValues(select, options, "Select date");
      if (selectedDateValue && options.some(function (o) { return o.value === selectedDateValue; })) {
        select.value = selectedDateValue;
      }
      return options;
    }

    function buildScheduleTimeOptions(details, selectedTimeValue, selectedDateValue) {
      var select = document.getElementById("routeTargetTime");
      if (!select) {
        return;
      }

      if (!selectedDateValue) {
        setSelectValues(select, [], "Select time");
        return;
      }

      var dateValue = new Date(selectedDateValue + "T00:00:00");
      var schedules = details && details.schedules ? details.schedules : [];
      var times = [];
      var seen = {};

      schedules.forEach(function (schedule) {
        if (!isScheduleActiveOnDate(schedule, dateValue)) {
          return;
        }
        var openMinutes = parseIsoDurationToMinutes(schedule.openTime);
        var closeMinutes = parseIsoDurationToMinutes(schedule.closeTime);
        var intervalMinutes = parseIsoDurationToMinutes(schedule.intervalTime) || 30;
        if (closeMinutes <= openMinutes) {
          return;
        }

        for (var minutes = openMinutes; minutes < closeMinutes; minutes += intervalMinutes) {
          var hh = toTwoDigits(Math.floor(minutes / 60) % 24);
          var mm = toTwoDigits(minutes % 60);
          var value = hh + ":" + mm;
          if (seen[value]) {
            continue;
          }
          seen[value] = true;
          times.push({
            value: value,
            label: value
          });
        }
      });

      times.sort(function (a, b) { return a.value.localeCompare(b.value); });
      setSelectValues(select, times, "Select time");
      if (selectedTimeValue && times.some(function (o) { return o.value === selectedTimeValue; })) {
        select.value = selectedTimeValue;
      }
    }

    function setRouteReferenceOptions(items, selectedValue) {
      var refSelect = document.getElementById("routeRefValue");
      if (!refSelect) {
        return;
      }
      setSelectOptions(refSelect, items || [], "Select reference");
      if (selectedValue) {
        refSelect.value = selectedValue;
      }
    }

    function loadRouteServices(queueCode, selectedServiceCode) {
      var serviceSelect = document.getElementById("routeTargetServiceId");
      if (!serviceSelect) {
        return Promise.resolve();
      }

      if (!queueCode) {
        activeRouteQueueDetails = null;
        setSelectOptions(serviceSelect, [], "Select service");
        setRouteReferenceOptions([], "");
        populateRouteDateOptions("");
        populateRouteTimeOptions("");
        return Promise.resolve();
      }

      var url = getQueueDetailsUrl + "?queueId=" + encodeURIComponent(queueCode);
      return getJson(url).then(function (res) {
        if (!res || !res.ok) {
          activeRouteQueueDetails = null;
          setSelectOptions(serviceSelect, [], "Select service");
          setRouteReferenceOptions([], "");
          populateRouteDateOptions("");
          populateRouteTimeOptions("");
          return;
        }

        activeRouteQueueDetails = res.data || null;
        setSelectOptions(serviceSelect, (res.data && res.data.services) || [], "Select service");
        if (selectedServiceCode) {
          serviceSelect.value = selectedServiceCode;
        }
        setRouteReferenceOptions((res.data && res.data.refOptions) || [], "");
        populateRouteDateOptions("");
        populateRouteTimeOptions("");
      }).catch(function () {
        activeRouteQueueDetails = null;
        setSelectOptions(serviceSelect, [], "Select service");
        setRouteReferenceOptions([], "");
        populateRouteDateOptions("");
        populateRouteTimeOptions("");
      });
    }

    function loadRouteQueues(selectedQueueCode, selectedServiceCode) {
      var queueSelect = document.getElementById("routeTargetQueueId");
      if (!queueSelect) {
        return Promise.resolve();
      }

      return getJson(getTransferQueuesUrl).then(function (res) {
        if (!res || !res.ok) {
          setSelectOptions(queueSelect, [], "Select queue");
          loadRouteServices("", "");
          return;
        }

        setSelectOptions(queueSelect, res.data || [], "Select queue");
        if (selectedQueueCode) {
          queueSelect.value = selectedQueueCode;
        }

        return loadRouteServices(queueSelect.value, selectedServiceCode || "");
      }).catch(function () {
        setSelectOptions(queueSelect, [], "Select queue");
        return loadRouteServices("", "");
      });
    }

    function closeModal(id) {
      var modal = document.getElementById(id);
      if (modal) {
        modal.classList.remove("show");
      }
      clearModalFeedback(id);
    }

    function openModal(id) {
      var modal = document.getElementById(id);
      if (modal) {
        modal.classList.add("show");
      }
      clearModalFeedback(id);
    }

    function getModalFeedbackElement(id) {
      return document.querySelector('[data-modal-feedback="' + id + '"]');
    }

    function clearModalFeedback(id) {
      var el = getModalFeedbackElement(id);
      if (!el) {
        return;
      }
      el.textContent = "";
      el.classList.remove("show");
      el.classList.remove("error");
      el.classList.remove("success");
    }

    function showModalFeedback(id, message, isError) {
      var el = getModalFeedbackElement(id);
      if (!el) {
        return;
      }
      el.textContent = message || "";
      el.classList.add("show");
      el.classList.toggle("error", !!isError);
      el.classList.toggle("success", !isError);
    }

    function setSelectValues(selectElement, values, placeholder) {
      if (!selectElement) {
        return;
      }

      selectElement.innerHTML = "";
      var placeholderOption = document.createElement("option");
      placeholderOption.value = "";
      placeholderOption.textContent = placeholder;
      selectElement.appendChild(placeholderOption);

      (values || []).forEach(function (item) {
        var option = document.createElement("option");
        option.value = item.value;
        option.textContent = item.label;
        selectElement.appendChild(option);
      });
    }

    function formatRouteDateLabel(dateValue) {
      var labels = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
      var months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
      return labels[dateValue.getDay()] + ", " + months[dateValue.getMonth()] + " " + dateValue.getDate() + ", " + dateValue.getFullYear();
    }

    function toTwoDigits(value) {
      return value < 10 ? "0" + value : String(value);
    }

    function populateRouteDateOptions(selectedDateValue) {
      var dateSelect = document.getElementById("routeTargetDate");
      if (!dateSelect) {
        return;
      }

      if (activeRouteQueueDetails && activeRouteQueueDetails.schedules && activeRouteQueueDetails.schedules.length) {
        buildScheduleDateOptions(activeRouteQueueDetails, selectedDateValue);
        return;
      }

      var base = new Date();
      base.setHours(0, 0, 0, 0);
      var options = [];
      for (var i = 0; i < 31; i++) {
        var dateValue = new Date(base.getTime());
        dateValue.setDate(base.getDate() + i);
        var yyyy = String(dateValue.getFullYear());
        var mm = toTwoDigits(dateValue.getMonth() + 1);
        var dd = toTwoDigits(dateValue.getDate());
        options.push({
          value: yyyy + "-" + mm + "-" + dd,
          label: formatRouteDateLabel(dateValue)
        });
      }

      setSelectValues(dateSelect, options, "Select date");
      if (selectedDateValue) {
        dateSelect.value = selectedDateValue;
      }
    }

    function populateRouteTimeOptions(selectedTimeValue) {
      var timeSelect = document.getElementById("routeTargetTime");
      if (!timeSelect) {
        return;
      }

      if (activeRouteQueueDetails && activeRouteQueueDetails.schedules && activeRouteQueueDetails.schedules.length) {
        var selectedDateValue = document.getElementById("routeTargetDate");
        buildScheduleTimeOptions(activeRouteQueueDetails, selectedTimeValue, selectedDateValue ? selectedDateValue.value : "");
        return;
      }

      var options = [];
      for (var hour = 0; hour < 24; hour++) {
        for (var minute = 0; minute < 60; minute += 30) {
          var hh = toTwoDigits(hour);
          var mm = toTwoDigits(minute);
          options.push({
            value: hh + ":" + mm,
            label: hh + ":" + mm
          });
        }
      }

      setSelectValues(timeSelect, options, "Select time");
      if (selectedTimeValue) {
        timeSelect.value = selectedTimeValue;
      }
    }

    function buildRouteTargetDateTime(dateValue, timeValue) {
      if (!dateValue) {
        return "";
      }
      if (!timeValue) {
        return dateValue;
      }
      return dateValue + " " + timeValue;
    }

    function toggleRouteDateRow() {
      var targetKind = document.getElementById("routeTargetKind");
      if (!targetKind) {
        return;
      }
      var showAppointmentFields = targetKind.value === "A";
      document.querySelectorAll(".route-appointment-only").forEach(function (row) {
        row.classList.toggle("is-hidden", !showAppointmentFields);
      });
    }

    function openRouteModal(mode, appointmentId, srcType, completionNotes) {
      var routeMode = document.getElementById("routeMode");
      var routeSrcType = document.getElementById("routeSrcType");
      var routeSrcId = document.getElementById("routeSrcId");
      var routeCompletionNotes = document.getElementById("routeCompletionNotes");
      var targetKind = document.getElementById("routeTargetKind");
      var targetQueueId = document.getElementById("routeTargetQueueId");
      var targetServiceId = document.getElementById("routeTargetServiceId");
      var targetDate = document.getElementById("routeTargetDate");
      var targetTime = document.getElementById("routeTargetTime");
      var refValue = document.getElementById("routeRefValue");
      var notes = document.getElementById("routeNotes");

      if (!routeMode || !routeSrcType || !routeSrcId || !targetKind) {
        return;
      }

      routeMode.value = mode;
      routeSrcType.value = srcType;
      routeSrcId.value = appointmentId;
      if (routeCompletionNotes) routeCompletionNotes.value = completionNotes || "";
      targetKind.value = srcType === "A" ? "A" : "W";
      if (targetQueueId) targetQueueId.value = "";
      if (targetServiceId) targetServiceId.value = "";
      populateRouteDateOptions("");
      populateRouteTimeOptions("");
      if (targetDate) targetDate.value = "";
      if (targetTime) targetTime.value = "";
      if (refValue) refValue.value = "";
      if (notes) notes.value = "";
      toggleRouteDateRow();
      loadRouteQueues("", "");
      openModal("serviceRouteModal");
    }

    function openEndServiceModal(appointmentId, srcType) {
      var srcIdInput = document.getElementById("endServiceSrcId");
      var srcTypeInput = document.getElementById("endServiceSrcType");
      var completionNotesInput = document.getElementById("endServiceCompletionNotes");
      if (!srcIdInput || !srcTypeInput) {
        return;
      }
      srcIdInput.value = appointmentId;
      srcTypeInput.value = srcType;
      if (completionNotesInput) completionNotesInput.value = "";
      openModal("endServiceModal");
    }

    function submitEndOnly(appointmentId, srcType, completionNotes) {
      return postForm(endServiceUrl, {
          appointmentId: appointmentId,
          srcType: srcType,
          additionalService: "N",
          targetQueueId: "",
          targetServiceId: "",
          targetKind: "",
          targetDate: "",
          refValue: "",
          notes: "",
          completionNotes: completionNotes || ""
        });
    }

    function updateRangeAndReload(startValue, endValue) {
      if (!startValue || !endValue) {
        return;
      }
      var url = new URL(window.location.href);
      url.searchParams.set("start", startValue);
      url.searchParams.set("end", endValue);
      window.location.assign(url.toString());
    }

    function clampRange(startInput, endInput) {
      if (!startInput || !endInput || !startInput.value || !endInput.value) {
        return;
      }

      if (endInput.value < startInput.value) {
        endInput.value = startInput.value;
      }
    }

    function applyTableFilters(container) {
      if (!container) {
        return;
      }

      var customerInput = container.querySelector('[data-filter="customer"]');
      var statusInput = container.querySelector('[data-filter="status"]');
      var startInput = container.querySelector('[data-filter="start"]');
      var endInput = container.querySelector('[data-filter="end"]');
      var customerValue = (customerInput && customerInput.value ? customerInput.value : "").toLowerCase().trim();
      var statusValue = (statusInput && statusInput.value ? statusInput.value : "").toLowerCase();
      var startValue = startInput && startInput.value ? startInput.value : "";
      var endValue = endInput && endInput.value ? endInput.value : "";
      var tables = container.parentElement
        ? Array.prototype.slice.call(container.parentElement.querySelectorAll("table"))
        : [];
      if (!tables.length) {
        tables = Array.prototype.slice.call(document.querySelectorAll(".table-card table"));
      }
      if (!tables.length) {
        return;
      }

      clampRange(startInput, endInput);
      startValue = startInput && startInput.value ? startInput.value : "";
      endValue = endInput && endInput.value ? endInput.value : "";

      tables.forEach(function (table) {
        table.querySelectorAll("tbody tr.accordion-toggle").forEach(function (row) {
          var rowStatus = (row.getAttribute("data-status") || "").toLowerCase();
          var rowDate = row.getAttribute("data-date") || "";
          var rowCustomer = (row.getAttribute("data-customer") || "").toLowerCase();
          var match = true;

          if (customerValue && rowCustomer.indexOf(customerValue) === -1) {
            match = false;
          }
          if (statusValue && statusValue !== "all" && rowStatus !== statusValue) {
            match = false;
          }
          if (startValue && rowDate < startValue) {
            match = false;
          }
          if (endValue && rowDate > endValue) {
            match = false;
          }

          row.classList.toggle("is-hidden", !match);
          var apptId = row.getAttribute("data-appointment-id");
          if (apptId) {
            document.querySelectorAll('.row-actions[data-appointment-id="' + apptId + '"]').forEach(function (detail) {
              detail.classList.toggle("is-hidden", !match);
              if (!match) {
                detail.classList.remove("is-open");
              }
            });
          }
        });

        var visibleRows = Array.prototype.filter.call(
          table.querySelectorAll("tbody tr.accordion-toggle"),
          function (row) { return !row.classList.contains("is-hidden"); }
        );
        var emptyRow = table.querySelector("tbody tr.table-empty");
        if (emptyRow) {
          emptyRow.classList.toggle("is-hidden", visibleRows.length > 0);
        }
      });
    }

    function bindAccordionRows() {
