            return;
          }
          closeModal("addAppointmentModal");
          queueLiveSync();
        });
      });
    }

    var saveAddWalkin = document.getElementById("saveAddWalkin");
    if (saveAddWalkin) {
      saveAddWalkin.addEventListener("click", function () {
        var payload = {
          queueId: document.getElementById("addWalkinQueueId") ? document.getElementById("addWalkinQueueId").value : "",
          serviceId: document.getElementById("addWalkinServiceId") ? document.getElementById("addWalkinServiceId").value : "",
          contactType: document.getElementById("addWalkinContactType") ? document.getElementById("addWalkinContactType").value : "",
          refValue: document.getElementById("addWalkinRefValue") ? document.getElementById("addWalkinRefValue").value : "",
          customerName: document.getElementById("addWalkinCustomerName") ? document.getElementById("addWalkinCustomerName").value : "",
          phone: document.getElementById("addWalkinPhone") ? document.getElementById("addWalkinPhone").value : "",
          notes: document.getElementById("addWalkinNotes") ? document.getElementById("addWalkinNotes").value : ""
        };

        if (!payload.queueId || !payload.customerName || !payload.phone) {
          showModalFeedback("addWalkinModal", "Queue, customer, and phone are required.", true);
          return;
        }

        postForm(addWalkinUrl, payload).then(function (res) {
          if (!res || !res.ok) {
            showModalFeedback("addWalkinModal", res && res.error ? res.error : "Could not add walk-in.", true);
            return;
          }
          closeModal("addWalkinModal");
          queueLiveSync();
        });
      });
    }

    bindAccordionRows();
    bindProviderActionButtons();
    bindMeetingLinks();
  })();
    </script>
}
