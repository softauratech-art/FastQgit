                                        <button class="btn small secondary" type="button" data-provider-action="true" data-action="begin" data-appointment-id="@row.AppointmentId" data-src-type="A" data-queue-id="@row.QueueId">Start</button>
                                        <button class="btn small secondary" type="button" data-provider-action="true" data-action="end" data-appointment-id="@row.AppointmentId" data-src-type="A" data-queue-id="@row.QueueId">End</button>
                                        <button class="btn small ghost" type="button" data-provider-action="true" data-action="transfer" data-appointment-id="@row.AppointmentId" data-src-type="A" data-queue-id="@row.QueueId">Transfer</button>
                                        <button class="btn small ghost meeting-link" type="button"
                                                data-appointment-id="@row.AppointmentId"
                                                data-src-type="A"
                                                data-date="@row.StartDateText"
                                                data-time="@row.StartTimeText"
                                                data-title="@row.ServiceType"
                                                data-customer="@row.CustomerName"
                                                data-phone="@row.Phone">
                                            Info
                                        </button>
                                        <button class="btn small ghost" type="button" data-provider-action="true" data-action="remove" data-appointment-id="@row.AppointmentId" data-src-type="A" data-queue-id="@row.QueueId">Cancelled</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    <tr class="table-empty is-hidden">
                        <td colspan="8" class="text-center">No results match the selected filters.</td>
                    </tr>
                </tbody>
            </table>
        </div>

        @if (serviceAccess.CanAddEntries)
        {
            <button class="btn primary" type="button" data-modal-open="addAppointmentModal">Add New Appointment</button>
        }
    </div>
}

