            <path d="M4 16a2 2 0 0 0 2 2h2v-5H6a2 2 0 0 0-2 2Z"></path>
            <path d="M20 16a2 2 0 0 1-2 2h-2v-5h2a2 2 0 0 1 2 2Z"></path>
