    var todayGlobalSearch = document.getElementById("todayGlobalSearch");
    if (todayGlobalSearch) {
      todayGlobalSearch.addEventListener("input", function () {
        var query = (todayGlobalSearch.value || "").trim().toLowerCase();
        document.querySelectorAll(".table-card table tbody tr.accordion-toggle").forEach(function (row) {
          var detail = findDetailRowByTarget(row.parentNode, row.getAttribute("data-target") || "");
          var haystack = (row.textContent || "").toLowerCase();
          var match = !query || haystack.indexOf(query) >= 0;
          row.classList.toggle("is-hidden", !match);
          if (detail) {
            detail.classList.toggle("is-hidden", !match);
          }
        });
      });
