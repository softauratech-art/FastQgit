                        <button class="btn small ghost" type="button" data-date-shift="1" data-date-target="start" aria-label="Next day">&gt;</button>
                        <span>to</span>
                        <button class="btn small ghost" type="button" data-date-shift="-1" data-date-target="end" aria-label="Previous day">&lt;</button>
                        <input id="walkinsEndDate" class="filter-input" type="date" data-filter="end" value="@endDate" />
                        <button class="btn small ghost" type="button" data-date-shift="1" data-date-target="end" aria-label="Next day">&gt;</button>
                    </div>
                </div>
                <button class="btn small ghost" type="button" data-filter-reset="true">Reset</button>
            </div>*@

        <div class="table-name-label">Walkins</div>
        <div class="table-card">
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th data-sort-key="time">Start</th>
                        <th data-sort-key="text">Queue</th>
                        <th data-sort-key="text">Type of Service</th>
                        <th data-sort-key="text">Name</th>
                        <th data-sort-key="text">Phone</th>
                        <th data-sort-key="text">Status</th>
                        <th data-sort-key="text">Contact</th>
                        <th class="text-center">Expand</th>
                    </tr>
                </thead>
                <tbody>
                    @if (walkinRows.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center">No walk-ins for today.</td>
                        </tr>
                    }
                    else
                    {
                        for (var i = 0; i < walkinRows.Count; i++)
                        {
                            var row = walkinRows[i];
                            var rowId = "walkin-" + row.AppointmentId.ToString(CultureInfo.InvariantCulture);
                            var rowStatus = row.Status.ToString();
                            var rowDate = row.ScheduledForUtc.ToString("yyyy-MM-dd");
                            var statusClass = row.Status == AppointmentStatus.Cancelled ? "error" : string.Empty;
                            var isLocked = row.Status == AppointmentStatus.InService && !string.Equals(row.StampUser ?? string.Empty, currentProviderId, StringComparison.OrdinalIgnoreCase);
                            <tr class="accordion-toggle @(isLocked ? "locked" : null)" data-target="@rowId" data-appointment-id="@row.AppointmentId" data-src-type="W" data-status="@rowStatus" data-date="@rowDate" data-customer="@row.CustomerName">
                                <td>@row.StartTimeText</td>
                                <td>@row.QueueName</td>
                                <td>@row.ServiceType</td>
                                <td>@row.CustomerName</td>
                                <td>@row.Phone</td>
                                <td class="@statusClass">@row.StatusText</td>
                                <td>@row.ContactMethod</td>
                                <td class="text-center">&darr;</td>
                            </tr>
                            <tr class="row-actions @(isLocked ? "locked" : null)" id="@rowId" data-appointment-id="@row.AppointmentId" data-src-type="W" data-queue-id="@row.QueueId">
                                <td colspan="8">
                                    <div class="action-bar">
                                        <button class="btn small primary" type="button" data-provider-action="true" data-action="arrive" data-appointment-id="@row.AppointmentId" data-src-type="W" data-queue-id="@row.QueueId">Check-In</button>
                                        <button class="btn small secondary" type="button" data-provider-action="true" data-action="begin" data-appointment-id="@row.AppointmentId" data-src-type="W" data-queue-id="@row.QueueId">Start</button>
                                        <button class="btn small secondary" type="button" data-provider-action="true" data-action="end" data-appointment-id="@row.AppointmentId" data-src-type="W" data-queue-id="@row.QueueId">End</button>
                                        <button class="btn small ghost" type="button" data-provider-action="true" data-action="transfer" data-appointment-id="@row.AppointmentId" data-src-type="W" data-queue-id="@row.QueueId">Transfer</button>
                                        <button class="btn small ghost meeting-link" type="button"
                                                data-appointment-id="@row.AppointmentId"
                                                data-src-type="W"
                                                data-date="@row.StartDateText"
                                                data-time="@row.StartTimeText"
                                                data-title="@row.ServiceType"
                                                data-customer="@row.CustomerName"
                                                data-phone="@row.Phone">
                                            Info
                                        </button>
                                        <button class="btn small ghost" type="button" data-provider-action="true" data-action="remove" data-appointment-id="@row.AppointmentId" data-src-type="W" data-queue-id="@row.QueueId">Cancelled</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    <tr class="table-empty is-hidden">
                        <td colspan="8" class="text-center">No results match the selected filters.</td>
                    </tr>
                </tbody>
            </table>
        </div>

        @if (serviceAccess.CanAddEntries)
        {
            <button class="btn primary" type="button" data-modal-open="addWalkinModal">Add Customer to Queue</button>
        }
    </div>
}

