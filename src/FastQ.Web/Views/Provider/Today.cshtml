@section Scripts {
    <script>
  (function () {
    var providerActionUrl = "@Url.Action("ProviderAction", "Provider")";
    var addAppointmentUrl = "@Url.Action("AddAppointment", "Provider")";
    var addWalkinUrl = "@Url.Action("AddWalkin", "Provider")";
    var transferUrl = "@Url.Action("TransferAppointment", "Provider")";
    var endServiceUrl = "@Url.Action("EndService", "Provider")";
    var saveServiceInfoUrl = "@Url.Action("SaveServiceInfo", "Provider")";
    var getTransferQueuesUrl = "@Url.Action("GetTransferQueues", "Provider")";
    var getTransferServicesUrl = "@Url.Action("GetTransferServices", "Provider")";
    var getQueueDetailsUrl = "@Url.Action("GetQueueDetails", "Provider")";
    var lookupCustomerByEmailUrl = "@Url.Action("LookupCustomerByEmail", "Provider")";
    var validatePermitUrl = "@Url.Action("ValidatePermit", "Provider")";
    var validateReferenceUrl = "@Url.Action("ValidateReference", "Provider")";
    var currentProviderId = "@(ViewBag.ProviderId as string ?? string.Empty)";
    var serviceAccess = @Html.Raw(JsonConvert.SerializeObject(serviceAccess));
    var activeRouteQueueDetails = null;
    var activeEntryQueueDetails = {
      addAppt: null,
      addWalkin: null
    };
    var permitValidationState = {
      addAppt: { seq: 0, pending: false, valid: false, message: "" },
      addWalkin: { seq: 0, pending: false, valid: false, message: "" }
    };
    var permitValidationTimers = {};
    var customerLookupTimers = {};
    var customerLookupRequestSeq = {};
    var todayNotifications = [];
    var todayNotificationUnreadCount = 0;
    var maxNotificationItems = 25;

    function postForm(url, data) {
      return fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
        credentials: "same-origin",
        body: new URLSearchParams(data).toString()
      }).then(function (r) { return r.json(); });
    }

    function getJson(url) {
      return fetch(url, {
        method: "GET",
        credentials: "same-origin"
      }).then(function (r) { return r.json(); });
    }

    function setSelectOptions(selectElement, items, placeholderText) {
      if (!selectElement) {
        return;
      }

      selectElement.innerHTML = "";
      var placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = placeholderText;
      selectElement.appendChild(placeholder);

      (items || []).forEach(function (item) {
        var option = document.createElement("option");
        option.value = item.code || "";
        option.textContent = item.name || item.code || "";
        selectElement.appendChild(option);
      });
    }

    function populateEntryModalOptions(prefix, details) {
      setSelectOptions(document.getElementById(prefix + "ServiceId"), details && details.services ? details.services : [], "Select service");
      setSelectOptions(document.getElementById(prefix + "ContactType"), details && details.contactOptions ? details.contactOptions : [], "Select contact type");
      setSelectOptions(document.getElementById(prefix + "RefValue"), details && details.refOptions ? details.refOptions : [], "Select reference");
      syncReferenceInputMeta(prefix);
      syncMeetingUrlField(prefix);
    }

    function loadEntryQueueDetails(prefix, queueCode) {
      if (!queueCode) {
        activeEntryQueueDetails[prefix] = null;
        populateEntryModalOptions(prefix, null);
        populateEntryModalDateTime(prefix, null);
        return Promise.resolve();
      }

      return getJson(getQueueDetailsUrl + "?queueId=" + encodeURIComponent(queueCode))
        .then(function (res) {
          var details = res && res.ok ? res.data : null;
          activeEntryQueueDetails[prefix] = details;
          populateEntryModalOptions(prefix, details);
          populateEntryModalDateTime(prefix, details);
        })
        .catch(function () {
          activeEntryQueueDetails[prefix] = null;
          populateEntryModalOptions(prefix, null);
          populateEntryModalDateTime(prefix, null);
        });
    }

    function loadEntryQueues(prefix) {
      var queueSelect = document.getElementById(prefix + "QueueId");
      if (!queueSelect) {
        return Promise.resolve();
      }

      return getJson(getTransferQueuesUrl)
        .then(function (res) {
          setSelectOptions(queueSelect, res && res.ok ? res.data : [], "Select queue");
        })
        .catch(function () {
          setSelectOptions(queueSelect, [], "Select queue");
        });
    }

    function clearAddEntryModal(prefix) {
      var fields = [
        "QueueId", "ServiceId", "ContactType", "RefValue", "PermitNumber",
        "StreetNumber", "StreetName", "StreetType",
        "Email", "FirstName", "LastName", "Phone", "MeetingUrl", "Notes"
      ];

      fields.forEach(function (suffix) {
        var input = document.getElementById(prefix + suffix);
        if (input) {
          input.value = "";
        }
      });

      activeEntryQueueDetails[prefix] = null;
      populateEntryModalOptions(prefix, null);
      populateEntryModalDateTime(prefix, null);
      setCustomerLookupState(prefix, false, null);
      resetPermitValidation(prefix);
      syncReferenceInputMeta(prefix);
      syncMeetingUrlField(prefix);
    }

    function getReferenceFieldMeta(code) {
      switch ((code || "").toUpperCase()) {
        case "A":
          return { label: "Address", placeholder: "Enter address", validatePermit: false, useAddressFields: true };
        case "C":
          return { label: "Case", placeholder: "Enter case", validatePermit: false, useAddressFields: false };
        case "G":
          return { label: "General", placeholder: "Enter general reference", validatePermit: false, useAddressFields: false };
        case "P":
          return { label: "Permit", placeholder: "Enter permit number", validatePermit: true, useAddressFields: false };
        default:
          return { label: "Reference Value", placeholder: "Enter reference value", validatePermit: false, useAddressFields: false };
      }
    }

    function getSelectedReferenceCode(prefix) {
      var refSelect = document.getElementById(prefix + "RefValue");
      return refSelect ? (refSelect.value || "").trim() : "";
    }

    function syncReferenceInputMeta(prefix) {
      var input = document.getElementById(prefix + "PermitNumber");
      var label = document.getElementById(prefix + "PermitNumberLabel");
      var addressRow = document.getElementById(prefix + "AddressRow");
      var referenceWrap = document.getElementById(prefix + "ReferenceValueWrap");
      if (!input) {
        return;
      }
      var meta = getReferenceFieldMeta(getSelectedReferenceCode(prefix));
      if (label) {
        label.textContent = meta.label;
      }
      input.placeholder = meta.placeholder;
      if (addressRow) {
        addressRow.classList.toggle("is-hidden", !meta.useAddressFields);
      }
      if (referenceWrap) {
        referenceWrap.classList.toggle("is-hidden", !!meta.useAddressFields);
      }
      resetPermitValidation(prefix);
    }

    function getAddressFieldIds(prefix) {
      return {
        streetNumberId: prefix + "StreetNumber",
        streetNameId: prefix + "StreetName",
        streetTypeId: prefix + "StreetType",
        statusId: prefix + "AddressStatus"
      };
    }

    function getPermitValidationIds(prefix) {
      var meta = getReferenceFieldMeta(getSelectedReferenceCode(prefix));
      return {
        inputId: prefix + "PermitNumber",
        statusId: prefix + (meta.useAddressFields ? "AddressStatus" : "PermitStatus")
      };
    }

    function setPermitValidationState(prefix, pending, valid, message) {
      permitValidationState[prefix] = permitValidationState[prefix] || { seq: 0, pending: false, valid: false, message: "" };
      permitValidationState[prefix].pending = !!pending;
      permitValidationState[prefix].valid = !!valid;
      permitValidationState[prefix].message = message || "";

      var ids = getPermitValidationIds(prefix);
      var status = document.getElementById(ids.statusId);
      var input = document.getElementById(ids.inputId);
      if (status) {
        status.textContent = message || "";
        status.style.color = pending ? "#6b7280" : (valid ? "#15803d" : "#b91c1c");
      }
      if (input) {
        input.setAttribute("aria-invalid", pending || valid ? "false" : (message ? "true" : "false"));
      }
    }

    function resetPermitValidation(prefix) {
      permitValidationState[prefix] = permitValidationState[prefix] || { seq: 0, pending: false, valid: false, message: "" };
      permitValidationState[prefix].seq += 1;
      setPermitValidationState(prefix, false, false, "");
      if (permitValidationTimers[prefix]) {
        clearTimeout(permitValidationTimers[prefix]);
        permitValidationTimers[prefix] = 0;
      }
    }

    function validatePermitNumber(prefix, immediate) {
      var ids = getPermitValidationIds(prefix);
      var input = document.getElementById(ids.inputId);
      if (!input) {
        return Promise.resolve(true);
      }

      var refCode = getSelectedReferenceCode(prefix);
      var meta = getReferenceFieldMeta(refCode);
      var referenceValue = (input.value || "").trim();
      var addressIds = getAddressFieldIds(prefix);
      var streetNumberInput = document.getElementById(addressIds.streetNumberId);
      var streetNameInput = document.getElementById(addressIds.streetNameId);
      var streetTypeInput = document.getElementById(addressIds.streetTypeId);
      var streetNumber = streetNumberInput ? (streetNumberInput.value || "").trim() : "";
      var streetName = streetNameInput ? (streetNameInput.value || "").trim() : "";
      var streetType = streetTypeInput ? (streetTypeInput.value || "").trim() : "";
      if (meta.useAddressFields) {
        if (!streetNumber) {
          setPermitValidationState(prefix, false, false, "Street number is required.");
          return Promise.resolve(false);
        }
        if (!streetName) {
          setPermitValidationState(prefix, false, false, "Street name is required.");
          return Promise.resolve(false);
        }
      } else if (!referenceValue) {
        setPermitValidationState(prefix, false, false, meta.label + " is required.");
        return Promise.resolve(false);
      }
      if (!meta.validatePermit && !meta.useAddressFields) {
        setPermitValidationState(prefix, false, true, "");
        return Promise.resolve(true);
      }

      var state = permitValidationState[prefix] || { seq: 0, pending: false, valid: false, message: "" };
      state.seq += 1;
      permitValidationState[prefix] = state;
      var requestSeq = state.seq;
      setPermitValidationState(prefix, true, false, meta.useAddressFields ? "Validating address..." : "Validating permit number...");

      var run = function () {
        return getJson(validateReferenceUrl
          + "?referenceType=" + encodeURIComponent(refCode)
          + "&enterValue=" + encodeURIComponent(referenceValue)
          + "&streetNumber=" + encodeURIComponent(streetNumber)
          + "&streetName=" + encodeURIComponent(streetName)
          + "&streetType=" + encodeURIComponent(streetType))
          .then(function (res) {
            if (!permitValidationState[prefix] || permitValidationState[prefix].seq !== requestSeq) {
              return false;
            }
            if (res && (res.ok || res.success)) {
              setPermitValidationState(prefix, false, true, meta.useAddressFields ? "Address validated." : "Permit number validated.");
              return true;
            }
            setPermitValidationState(prefix, false, false, res && (res.error || res.message) ? (res.error || res.message) : (meta.useAddressFields ? "Address is invalid." : "Permit number is invalid."));
            return false;
          })
          .catch(function () {
            if (!permitValidationState[prefix] || permitValidationState[prefix].seq !== requestSeq) {
              return false;
            }
            setPermitValidationState(prefix, false, false, meta.useAddressFields ? "Could not validate address." : "Could not validate permit number.");
            return false;
          });
      };

      if (immediate) {
        return run();
      }

      return new Promise(function (resolve) {
        if (permitValidationTimers[prefix]) {
          clearTimeout(permitValidationTimers[prefix]);
        }
        permitValidationTimers[prefix] = setTimeout(function () {
          run().then(resolve);
        }, 350);
      });
    }

