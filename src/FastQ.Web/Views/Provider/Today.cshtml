    function getStatusTextForDisplay(normalizedStatus) {
      if (normalizedStatus === "arrived") return "ARRIVED";
      if (normalizedStatus === "inservice") return "IN PROGRESS";
      if (normalizedStatus === "completed") return "DONE";
      if (normalizedStatus === "cancelled") return "REMOVED";
      if (normalizedStatus === "scheduled") return "SCHEDULED";
      if (normalizedStatus === "transferredout") return "TRANSFERRED";
