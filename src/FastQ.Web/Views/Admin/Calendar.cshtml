            function lookupCustomerByEmail(prefix) {
                var timerKey = prefix || "_default";
                if (customerLookupTimers[timerKey]) {
                    clearTimeout(customerLookupTimers[timerKey]);
                    customerLookupTimers[timerKey] = 0;
                }
                var emailInput = document.getElementById(prefix === "walkin" ? "walkinEmail" : "email");
                if (!emailInput) {
                    return;
                }
                var email = (emailInput.value || "").trim();
                if (!email) {
                    setCustomerLookupState(prefix, false, null);
                    return;
                }
                customerLookupRequestSeq[timerKey] = (customerLookupRequestSeq[timerKey] || 0) + 1;
                var requestSeq = customerLookupRequestSeq[timerKey];
                setCustomerLookupLoading(prefix, true);
                getJson(lookupCustomerByEmailUrl + "?email=" + encodeURIComponent(email))
                    .then(function (res) {
                        if (customerLookupRequestSeq[timerKey] !== requestSeq) {
                            return;
                        }
                        if (!res || !res.ok || !res.found) {
                            setCustomerLookupState(prefix, false, null);
                            return;
                        }
                        setCustomerLookupState(prefix, true, res.data || {});
                    })
                    .catch(function () {
                        if (customerLookupRequestSeq[timerKey] !== requestSeq) {
                            return;
                        }
                        setCustomerLookupState(prefix, false, null);
                    });
            }

            function queueCustomerLookupByEmail(prefix) {
