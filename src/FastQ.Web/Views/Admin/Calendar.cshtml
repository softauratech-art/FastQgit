            function setPermitValidationState(kind, pending, valid, message) {
                permitValidationState[kind] = permitValidationState[kind] || { seq: 0, pending: false, valid: false, message: "" };
                permitValidationState[kind].pending = !!pending;
                permitValidationState[kind].valid = !!valid;
                permitValidationState[kind].message = message || "";

                var cfg = getPermitFieldConfig(kind);
                var status = document.getElementById(cfg.statusId);
                var input = document.getElementById(cfg.inputId);
                if (status) {
                    status.textContent = message || "";
                    status.style.color = pending ? "#6b7280" : (valid ? "#15803d" : "#b91c1c");
                }
                if (input) {
                    input.setAttribute("aria-invalid", pending || valid ? "false" : (message ? "true" : "false"));
                }
            }

            function validatePermitNumber(kind, immediate) {
                var cfg = getPermitFieldConfig(kind);
                var input = document.getElementById(cfg.inputId);
                if (!input) {
                    return Promise.resolve(true);
                }

                var referenceValue = (input.value || "").trim();
                var streetNumberInput = document.getElementById(cfg.streetNumberId);
                var streetNameInput = document.getElementById(cfg.streetNameId);
                var streetTypeInput = document.getElementById(cfg.streetTypeId);
                var streetNumber = streetNumberInput ? (streetNumberInput.value || "").trim() : "";
                var streetName = streetNameInput ? (streetNameInput.value || "").trim() : "";
                var streetType = streetTypeInput ? (streetTypeInput.value || "").trim() : "";
                var meta = getReferenceFieldMeta(getSelectedReferenceCode(kind));
                if (meta.useAddressFields) {
                    if (!streetNumber) {
                        setPermitValidationState(kind, false, false, "Street number is required.");
                        return Promise.resolve(false);
                    }
                    if (!streetName) {
                        setPermitValidationState(kind, false, false, "Street name is required.");
                        return Promise.resolve(false);
                    }
                } else if (!referenceValue) {
                    setPermitValidationState(kind, false, false, meta.label + " is required.");
                    return Promise.resolve(false);
                }
                if (!meta.validatePermit && !meta.useAddressFields) {
                    setPermitValidationState(kind, false, true, "");
                    return Promise.resolve(true);
                }

                var state = permitValidationState[kind] || { seq: 0, pending: false, valid: false, message: "" };
                state.seq += 1;
                permitValidationState[kind] = state;
                var requestSeq = state.seq;
                setPermitValidationState(kind, true, false, meta.useAddressFields ? "Validating address..." : "Validating permit number...");

                var run = function () {
                    return getJson(validateReferenceUrl
                        + "?referenceType=" + encodeURIComponent(getSelectedReferenceCode(kind))
                        + "&enterValue=" + encodeURIComponent(referenceValue)
                        + "&streetNumber=" + encodeURIComponent(streetNumber)
                        + "&streetName=" + encodeURIComponent(streetName)
                        + "&streetType=" + encodeURIComponent(streetType))
                        .then(function (res) {
                            if (!permitValidationState[kind] || permitValidationState[kind].seq !== requestSeq) {
                                return false;
                            }
                            if (res && (res.ok || res.success)) {
                                setPermitValidationState(kind, false, true, meta.useAddressFields ? "Address validated." : "Permit number validated.");
                                return true;
                            }
                            setPermitValidationState(kind, false, false, res && (res.error || res.message) ? (res.error || res.message) : (meta.useAddressFields ? "Address is invalid." : "Permit number is invalid."));
                            return false;
                        })
                        .catch(function () {
                            if (!permitValidationState[kind] || permitValidationState[kind].seq !== requestSeq) {
                                return false;
                            }
                            setPermitValidationState(kind, false, false, meta.useAddressFields ? "Could not validate address." : "Could not validate permit number.");
                            return false;
                        });
                };

                if (immediate) {
                    return run();
                }

                return new Promise(function (resolve) {
                    if (permitValidationTimers[kind]) {
                        clearTimeout(permitValidationTimers[kind]);
                    }
                    permitValidationTimers[kind] = setTimeout(function () {
                        run().then(resolve);
                    }, 350);
                });
            }

            function canAction(status, actionName, queueId) {
                if (!hasQueuePermission(actionName, queueId)) {
                    return false;
                }
                var finished = status === "completed" || status === "cancelled" || status === "closedbysystem" || status === "transferredout";
                if (finished) {
                    return false;
                }
                if (actionName === "arrive") {
                    return status === "scheduled";
                }
                if (actionName === "begin") {
                    return status === "arrived" || status === "scheduled";
                }
                if (actionName === "end") {
                    return status === "inservice";
                }
                if (actionName === "remove") {
                    return !finished;
                }
                return true;
            }

            function bindProviderActionButtons() {
                document.querySelectorAll("[data-provider-action]").forEach(function (btn) {
                    var action = (btn.getAttribute("data-action") || "").toLowerCase();
                    var appointmentId = btn.getAttribute("data-appointment-id");
                    var queueId = btn.getAttribute("data-queue-id");
                    var status = appointmentId ? getStatusForAppointment(appointmentId) : "";
                    btn.disabled = !canAction(status, action, queueId);

                    if (btn.getAttribute("data-bound-provider-action") === "1") {
                        return;
                    }
                    btn.setAttribute("data-bound-provider-action", "1");
                    btn.addEventListener("click", function (event) {
                        event.preventDefault();
                        event.stopPropagation();

                        var appointmentId = btn.getAttribute("data-appointment-id");
                        var action = (btn.getAttribute("data-action") || "").toLowerCase();
                        var srcType = (btn.getAttribute("data-src-type") || "A").toUpperCase();
                        var queueId = btn.getAttribute("data-queue-id");
                        if (!appointmentId || !action) {
                            return;
                        }

                        var status = getStatusForAppointment(appointmentId);
                        if (!canAction(status, action, queueId)) {
                            window.alert("Action not allowed for the current status.");
                            return;
                        }

                        if (action === "transfer") {
                            openRouteModal("transfer", appointmentId, srcType);
                            return;
                        }

                        if (action === "end") {
                            openEndServiceModal(appointmentId, srcType);
                            return;
                        }

                        postForm(providerActionUrl, { action: action, appointmentId: appointmentId, srcType: srcType })
                            .then(function (res) {
                                if (!res || !res.ok) {
                                    window.alert(res && res.error ? res.error : "Action failed.");
                                    return;
                                }
                                queueLiveSync();
                            });
                    });
                });
            }

