                    }
                    validatePermitNumber("walkin", true).then(function (isValid) {
                        if (!isValid) {
                            window.alert(permitValidationState.walkin.message || "Reference value is invalid.");
                            return;
                        }

                        var formData = new FormData(addWalkinForm);
                        fetch(addWalkinForm.action, {
                            method: "POST",
                            headers: { "X-Requested-With": "XMLHttpRequest" },
                            credentials: "same-origin",
                            body: new URLSearchParams(formData)
                        })
                            .then(function (res) { return res.json(); })
                            .then(function (res) {
                                if (!res || !res.ok) {
                                    window.alert(res && res.error ? res.error : "Could not add walk-in.");
                                    return;
                                }
                                closeModal("addWalkinModal");
                                queueLiveSync();
                            })
                            .catch(function () {
                                window.alert("Could not add walk-in.");
                            });
                    });
                });
            }

            document.querySelectorAll("[data-end-choice]").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    var choice = btn.getAttribute("data-end-choice");
                    var srcIdInput = document.getElementById("endServiceSrcId");
                    var srcTypeInput = document.getElementById("endServiceSrcType");
                    var appointmentId = srcIdInput ? srcIdInput.value : "";
                    var srcType = srcTypeInput ? srcTypeInput.value : "";
                    if (!appointmentId || !srcType) {
                        closeModal("endServiceModal");
                        return;
                    }

                    if (choice === "end-add") {
                        closeModal("endServiceModal");
                        openRouteModal("end-add", appointmentId, srcType);
                        return;
                    }

                    submitEndOnly(appointmentId, srcType)
                        .then(function (res) {
                            if (!res || !res.ok) {
                                window.alert(res && res.error ? res.error : "End service failed.");
                                return;
                            }
                            closeModal("endServiceModal");
                            queueLiveSync();
                        });
                });
            });

            var saveMeeting = document.getElementById("saveMeeting");
            if (saveMeeting) {
                saveMeeting.addEventListener("click", function () {
                    var mid = document.getElementById("mid");
                    var urlInput = document.getElementById("mURL");
                    var notesInput = document.getElementById("mNotes");
                    if (!mid) {
                        return;
                    }

                    var appointmentId = mid.getAttribute("data-appointment-id");
                    var srcType = mid.getAttribute("data-src-type") || "A";
                    var payload = {
                        appointmentId: appointmentId,
                        srcType: srcType,
                        webexUrl: urlInput ? urlInput.value : "",
                        notes: notesInput ? notesInput.value : ""
                    };

                    postForm(saveServiceInfoUrl, payload)
                        .then(function (res) {
                            if (!res || !res.ok) {
                                window.alert(res && res.error ? res.error : "Save failed.");
                                return;
                            }
                            closeModal("meetingModal");
                        });
                });
            }

            var routeTargetKind = document.getElementById("routeTargetKind");
            if (routeTargetKind) {
                routeTargetKind.addEventListener("change", function () {
                    toggleRouteDateRow();
                    populateRouteDateOptions("");
                    populateRouteTimeOptions("");
                });
                toggleRouteDateRow();
            }

            var routeTargetDate = document.getElementById("routeTargetDate");
            if (routeTargetDate) {
                routeTargetDate.addEventListener("change", function () {
                    populateRouteTimeOptions("");
                });
            }

            var routeTargetQueueId = document.getElementById("routeTargetQueueId");
            if (routeTargetQueueId) {
                routeTargetQueueId.addEventListener("change", function () {
                    loadRouteServices(routeTargetQueueId.value || "", "");
                });
            }

            var saveRoute = document.getElementById("saveRoute");
            if (saveRoute) {
                saveRoute.addEventListener("click", function () {
                    var routeMode = document.getElementById("routeMode");
                    var routeSrcType = document.getElementById("routeSrcType");
                    var routeSrcId = document.getElementById("routeSrcId");
                    var targetKindInput = document.getElementById("routeTargetKind");
                    var targetQueueIdInput = document.getElementById("routeTargetQueueId");
                    var targetServiceIdInput = document.getElementById("routeTargetServiceId");
                    var targetDateInput = document.getElementById("routeTargetDate");
                    var targetTimeInput = document.getElementById("routeTargetTime");
                    var refValueInput = document.getElementById("routeRefValue");
                    var notesInput = document.getElementById("routeNotes");

                    var mode = routeMode ? routeMode.value : "";
                    var srcType = routeSrcType ? routeSrcType.value : "";
                    var appointmentId = routeSrcId ? routeSrcId.value : "";
                    var targetKind = targetKindInput ? targetKindInput.value : "";
                    var targetQueueId = targetQueueIdInput ? targetQueueIdInput.value : "";
                    var targetServiceId = targetServiceIdInput ? targetServiceIdInput.value : "";
                    var targetDate = targetDateInput ? targetDateInput.value : "";
                    var targetTime = targetTimeInput ? targetTimeInput.value : "";
                    var refValue = refValueInput ? refValueInput.value : "";
                    var notes = notesInput ? notesInput.value : "";
                    var targetDateTime = buildRouteTargetDateTime(targetDate, targetTime);

                    if (!appointmentId || !srcType || !targetQueueId) {
                        window.alert("Source and target queue are required.");
                        return;
                    }
                    if (targetKind === "A" && (!targetDate || !targetTime)) {
                        window.alert("Target date and time are required for appointment target.");
                        return;
                    }

                    if (mode === "transfer") {
                        postForm(transferUrl, {
                            appointmentId: appointmentId,
                            srcType: srcType,
                            targetQueueId: targetQueueId,
                            targetKind: targetKind,
                            targetServiceId: targetServiceId || "",
                            targetDate: targetDateTime || "",
                            refValue: refValue || "",
                            notes: notes || ""
                        })
                            .then(function (res) {
                                if (!res || !res.ok) {
                                    window.alert(res && res.error ? res.error : "Transfer failed.");
                                    return;
                                }
                                closeModal("serviceRouteModal");
                                queueLiveSync();
                            });
                        return;
                    }

                    if (mode === "end-add") {
                        postForm(endServiceUrl, {
                            appointmentId: appointmentId,
                            srcType: srcType,
                            additionalService: "Y",
                            targetQueueId: targetQueueId,
                            targetServiceId: targetServiceId || "",
                            targetKind: targetKind,
                            targetDate: targetDateTime || "",
                            refValue: refValue || "",
                            notes: notes || ""
                        })
                            .then(function (res) {
                                if (!res || !res.ok) {
                                    window.alert(res && res.error ? res.error : "End and add failed.");
                                    return;
                                }
                                closeModal("serviceRouteModal");
                                queueLiveSync();
                            });
                    }
                });
            }

            bindProviderActionButtons();
            bindMeetingLinks();

            if (reopenOnError) {
                openModal("addAppointmentModal");
            }
        })();
    </script>
}
