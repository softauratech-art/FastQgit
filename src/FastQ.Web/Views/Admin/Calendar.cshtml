            function hasQueuePermission(actionName, queueId) {
                var access = serviceAccess || {};
                var numericQueueId = parseInt(queueId || "0", 10);
                var providerQueueIds = Array.isArray(access.ProviderQueueIds) ? access.ProviderQueueIds : [];
                var queueAdminQueueIds = Array.isArray(access.QueueAdminQueueIds) ? access.QueueAdminQueueIds : [];
                var providerHasQueue = providerQueueIds.indexOf(numericQueueId) >= 0;
                var queueAdminHasQueue = queueAdminQueueIds.indexOf(numericQueueId) >= 0;

                if (access.IsAdmin) {
                    return true;
                }
                if (actionName === "arrive") {
                    return !!access.IsHost || !!access.IsProvider || queueAdminHasQueue;
                }
                if (actionName === "transfer") {
                    return !!access.IsHost || !!access.IsProvider || queueAdminHasQueue;
                }
                if (actionName === "remove") {
                    return !!access.IsHost || !!access.IsProvider || queueAdminHasQueue;
                }
                if (actionName === "info") {
                    return !!access.IsHost || !!access.IsProvider || queueAdminHasQueue;
                }
                if (actionName === "begin" || actionName === "end") {
                    return providerHasQueue || queueAdminHasQueue;
                }
                return false;
            }

