@using System.Globalization
@using Newtonsoft.Json
@model FastQ.Web.Models.AdminDashboardViewModel

@{
    ViewBag.Title = "Calendar";
    var previousMonth = Model.DisplayMonth.AddMonths(-1);
    var nextMonth = Model.DisplayMonth.AddMonths(1);
    var modalDate = Model.SelectedDate == default(DateTime) ? DateTime.Today : Model.SelectedDate;
    var monthNames = System.Globalization.DateTimeFormatInfo.InvariantInfo.MonthNames.Take(12).ToList();
    var currentYear = Model.DisplayMonth.Year;
    var yearOptions = Enumerable.Range(currentYear - 2, 6).ToList();
    var serviceAccess = ViewBag.ServiceAccess as FastQ.Web.Models.ServicePageAccess ?? new FastQ.Web.Models.ServicePageAccess();
    var currentProviderId = ((ViewBag.ProviderId as string) ?? string.Empty).Trim();
}

@section Head {
    <style>
        .calendar-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .calendar-nav {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .calendar-nav .month-label {
            min-width: 180px;
            text-align: center;
            font-size: 20px;
            font-weight: 700;
            color: #0f172a;
        }

        .calendar-jump {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 10px;
            border-radius: 14px;
            background: #f8fafc;
            border: 1px solid #dbe4f0;
        }

        .calendar-jump select {
            border: 0;
            background: transparent;
            font: inherit;
            font-weight: 700;
            color: #0f172a;
            padding: 2px 4px;
            min-width: 0;
        }

        .calendar-shell {
            display: grid;
            grid-template-columns: minmax(0, 1.65fr) minmax(320px, 1fr);
            gap: 20px;
        }

        .calendar-panel,
        .agenda-panel {
            background: #fff;
            border: 1px solid #dbe4f0;
            border-radius: 20px;
            box-shadow: 0 18px 48px rgba(15, 23, 42, 0.08);
        }

        .calendar-panel {
            padding: 20px;
        }

        .agenda-panel {
            padding: 22px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .calendar-weekdays,
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 10px;
        }

        .calendar-weekdays {
            margin-bottom: 10px;
        }

        .calendar-weekday {
            text-align: center;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #64748b;
        }

        .calendar-day {
            min-height: 96px;
            border-radius: 16px;
            padding: 12px;
            border: 1px solid #dbe4f0;
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .calendar-day.is-selected {
            border-color: #0f766e;
            box-shadow: inset 0 0 0 1px #0f766e;
            background: linear-gradient(180deg, #f0fdfa 0%, #ecfeff 100%);
        }

        .calendar-day.is-muted {
            opacity: 0.42;
            background: #f8fafc;
        }

        .calendar-day.is-today .day-number {
            color: #0f766e;
        }

        .calendar-day-link {
            color: inherit;
            text-decoration: none;
            height: 100%;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .day-number {
            font-size: 15px;
            font-weight: 700;
            color: #0f172a;
        }

        .day-meta {
            margin-top: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            font-size: 12px;
            color: #475569;
        }

        .day-count {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 26px;
            height: 26px;
            padding: 0 8px;
            border-radius: 999px;
            background: #0f172a;
            color: #fff;
            font-weight: 700;
        }

        .agenda-header h3 {
            margin: 0;
            font-size: 22px;
        }

        .agenda-header p {
            margin: 6px 0 0;
            color: #64748b;
        }

        .agenda-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .agenda-item {
            border: 1px solid #dbe4f0;
            border-radius: 16px;
            padding: 14px;
            background: #f8fafc;
        }

        .agenda-item.locked {
            opacity: 0.45;
        }

        .agenda-item.locked .agenda-actions {
            pointer-events: none;
        }

        .agenda-time {
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .agenda-title {
            margin-top: 6px;
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
        }

        .agenda-detail {
            margin-top: 4px;
            font-size: 13px;
            color: #475569;
        }

        .agenda-notes {
            margin-top: 8px;
            padding-top: 8px;
            border-top: 1px dashed #cbd5e1;
            font-size: 13px;
            color: #334155;
        }

        .agenda-actions {
            margin-top: 12px;
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            flex-wrap: wrap;
        }

        .feedback-banner {
            margin-bottom: 16px;
            padding: 12px 14px;
            border-radius: 14px;
            font-size: 14px;
            font-weight: 600;
        }

        .feedback-banner.success {
            background: #ecfdf5;
            border: 1px solid #a7f3d0;
            color: #065f46;
        }

        .feedback-banner.error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
        }

        .empty-state {
            padding: 18px;
            border-radius: 16px;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            color: #64748b;
        }

        .calendar-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.6);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            padding: 24px;
        }

        .calendar-modal-backdrop.show {
            display: flex;
        }

        .calendar-modal {
            width: min(720px, 100%);
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.25);
            overflow: hidden;
        }

        .calendar-modal-header,
        .calendar-modal-footer {
            padding: 18px 22px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            border-bottom: 1px solid #e2e8f0;
        }

        .calendar-modal-footer {
            border-bottom: 0;
            border-top: 1px solid #e2e8f0;
            justify-content: flex-end;
        }

        .calendar-modal-header h3 {
            margin: 0;
            font-size: 20px;
        }

        .calendar-modal-body {
            padding: 22px;
        }

        .calendar-form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }

        .calendar-field {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .calendar-field.full {
            grid-column: 1 / -1;
        }

        .calendar-field label {
            font-size: 13px;
            font-weight: 700;
            color: #334155;
        }

        .calendar-field input,
        .calendar-field select,
        .calendar-field textarea {
            width: 100%;
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            padding: 10px 12px;
            font: inherit;
            color: #0f172a;
            background: #fff;
        }

        .calendar-field textarea {
            min-height: 88px;
            resize: vertical;
        }

        .modal-backdrop.show {
            display: flex;
        }

        .modal {
            width: min(560px, 92vw);
            border-radius: 18px;
            background: #ffffff;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.25);
            padding: 18px 20px;
        }

        .modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .modal-title {
            margin: 0;
            font-size: 18px;
            font-weight: 700;
        }

        .modal-body {
            display: grid;
            gap: 10px;
            margin-top: 12px;
        }

        .field-row {
            display: grid;
            grid-template-columns: 120px 1fr;
            gap: 12px;
            align-items: center;
        }

        .modal-body input,
        .modal-body textarea,
        .modal-body select {
            padding: 8px 10px;
            border-radius: 8px;
            border: 1px solid rgba(0, 0, 0, 0.15);
            font-size: 13px;
            width: 100%;
        }

        .helper-text {
            font-size: 12px;
            color: #5b5b5b;
        }

        .autofilled-lock {
            background: #f3f4f6 !important;
            color: #6b7280;
            cursor: not-allowed;
        }

        .lookup-input-wrap {
            position: relative;
        }

        .lookup-spinner {
            position: absolute;
            right: 10px;
            top: 50%;
            width: 14px;
            height: 14px;
            margin-top: -7px;
            border: 2px solid #cbd5e1;
            border-top-color: #0f766e;
            border-radius: 50%;
            animation: lookup-spin 0.8s linear infinite;
            display: none;
        }

        .lookup-input-wrap.is-loading .lookup-spinner {
            display: block;
        }

        .lookup-input-wrap.is-loading input {
            padding-right: 34px;
        }

        @@keyframes lookup-spin {
            to { transform: rotate(360deg); }
        }

        .modal-footer {
            margin-top: 14px;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .route-modal .modal {
            width: min(680px, 92vw);
            border-radius: 18px;
        }

        .route-form-row {
            display: grid;
            grid-template-columns: 160px 1fr;
            gap: 12px;
            align-items: center;
        }

        .route-form-row label {
            font-weight: 600;
            color: #374151;
        }

        .is-hidden {
            display: none;
        }

        @@media (max-width: 1080px) {
            .calendar-shell {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 720px) {
            .calendar-form-grid {
                grid-template-columns: 1fr;
            }

            .calendar-day {
                min-height: 78px;
                padding: 10px;
            }

            .calendar-nav .month-label {
                min-width: auto;
            }

            .route-form-row,
            .field-row {
                grid-template-columns: 1fr;
                align-items: start;
            }
        }
    </style>
}

@section PageHeader {
    <div>
        <div class="topbar-title">Appointment Calendar</div>
        <div class="topbar-sub">
            Month view by default with a selected-day details panel and staff-assisted booking.
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.FeedbackMessage))
{
    <div class="feedback-banner @(Model.FeedbackIsError ? "error" : "success")">@Model.FeedbackMessage</div>
}

<div class="calendar-toolbar">
    <div class="calendar-nav">
        <button class="btn ghost" type="button" data-calendar-shift="-1">Previous</button>
        <div class="month-label">@Model.DisplayMonth.ToString("MMMM yyyy", CultureInfo.InvariantCulture)</div>
        <button class="btn ghost" type="button" data-calendar-shift="1">Next</button>
        <div class="calendar-jump">
            <select id="calendarMonthSelect" aria-label="Select month">
                @for (var monthIndex = 1; monthIndex <= 12; monthIndex++)
                {
                    <option value="@monthIndex" @(monthIndex == Model.DisplayMonth.Month ? "selected" : null)>@monthNames[monthIndex - 1]</option>
                }
            </select>
            <select id="calendarYearSelect" aria-label="Select year">
                @foreach (var year in yearOptions)
                {
                    <option value="@year" @(year == currentYear ? "selected" : null)>@year</option>
                }
            </select>
            <button class="btn small ghost" type="button" id="calendarTodayBtn">Today</button>
        </div>
    </div>
    @if (serviceAccess.CanAddEntries)
    {
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <button type="button" class="btn secondary" data-modal-open="addAppointmentModal">Add Appointment</button>
            <button type="button" class="btn ghost" data-modal-open="addWalkinModal">Add Walk-In</button>
        </div>
    }
</div>

<div class="calendar-shell">
    <section class="calendar-panel">
        <div class="calendar-weekdays">
            <div class="calendar-weekday">Sun</div>
            <div class="calendar-weekday">Mon</div>
            <div class="calendar-weekday">Tue</div>
            <div class="calendar-weekday">Wed</div>
            <div class="calendar-weekday">Thu</div>
            <div class="calendar-weekday">Fri</div>
            <div class="calendar-weekday">Sat</div>
        </div>

        <div class="calendar-grid">
            @foreach (var day in Model.CalendarDays)
            {
                var dayClass = "calendar-day";
                if (!day.IsCurrentMonth)
                {
                    dayClass += " is-muted";
                }
                if (day.IsSelected)
                {
                    dayClass += " is-selected";
                }
                if (day.IsToday)
                {
                    dayClass += " is-today";
                }

                <div class="@dayClass">
                    @if (day.IsCurrentMonth)
                    {
                        <a class="calendar-day-link" href="@Url.Action("Index", "Calendar", new { month = Model.DisplayMonth.ToString("yyyy-MM-01"), selectedDate = day.Date.ToString("yyyy-MM-dd") })">
                            <div class="day-number">@day.Date.Day</div>
                            <div class="day-meta">
                                <span>@(day.AppointmentCount == 1 ? "1 appt" : day.AppointmentCount + " appts")</span>
                                @if (day.AppointmentCount > 0)
                                {
                                    <span class="day-count">@day.AppointmentCount</span>
                                }
                            </div>
                        </a>
                    }
                    else
                    {
                        <div class="day-number">@day.Date.Day</div>
                    }
                </div>
            }
        </div>
    </section>

    <aside class="agenda-panel">
        <div class="agenda-header">
            <h3>@Model.SelectedDate.ToString("dddd, MMMM d", CultureInfo.InvariantCulture)</h3>
            <p>@(string.IsNullOrWhiteSpace(Model.LocationName) ? "Primary location" : Model.LocationName)</p>
        </div>

        @if (Model.SelectedDayAppointments.Any())
        {
            <div class="agenda-list">
                @foreach (var item in Model.SelectedDayAppointments)
                {
                    var isLocked = item.Status == FastQ.Data.Entities.AppointmentStatus.InService && !string.Equals(item.StampUser ?? string.Empty, currentProviderId, System.StringComparison.OrdinalIgnoreCase);
                    <div class="agenda-item @(isLocked ? "locked" : null)" data-appointment-id="@item.AppointmentId" data-queue-id="@item.QueueId" data-status="@item.Status" data-src-type="@item.SrcType">
                        <div class="agenda-time">@item.StartTimeText</div>
                        <div class="agenda-title">@item.CustomerName</div>
                        <div class="agenda-detail">@item.EntryKind</div>
                        <div class="agenda-detail">@item.QueueName</div>
                        <div class="agenda-detail">@item.ContactMethod | @item.StatusText | @item.Phone</div>
                        @if (!string.IsNullOrWhiteSpace(item.MeetingUrl))
                        {
                            <div class="agenda-detail"><a href="@item.MeetingUrl" target="_blank" rel="noopener">Open meeting link</a></div>
                        }
                        <div class="agenda-notes">@item.Notes</div>
                        <div class="agenda-actions">
                            <button class="btn small primary" type="button" data-provider-action="true" data-action="arrive" data-appointment-id="@item.AppointmentId" data-src-type="@item.SrcType" data-queue-id="@item.QueueId">Check-In</button>
                            <button class="btn small secondary" type="button" data-provider-action="true" data-action="begin" data-appointment-id="@item.AppointmentId" data-src-type="@item.SrcType" data-queue-id="@item.QueueId">Start</button>
                            <button class="btn small secondary" type="button" data-provider-action="true" data-action="end" data-appointment-id="@item.AppointmentId" data-src-type="@item.SrcType" data-queue-id="@item.QueueId">End</button>
                            <button class="btn small ghost" type="button" data-provider-action="true" data-action="transfer" data-appointment-id="@item.AppointmentId" data-src-type="@item.SrcType" data-queue-id="@item.QueueId">Transfer</button>
                            <button class="btn small ghost meeting-link" type="button"
                                    data-appointment-id="@item.AppointmentId"
                                    data-src-type="@item.SrcType"
                                    data-date="@item.StartDateText"
                                    data-time="@item.StartTimeText"
                                    data-title="@item.ServiceType"
                                    data-customer="@item.CustomerName"
                                    data-phone="@item.Phone">
                                Info
                            </button>
                            <button class="btn small ghost" type="button" data-provider-action="true" data-action="remove" data-appointment-id="@item.AppointmentId" data-src-type="@item.SrcType" data-queue-id="@item.QueueId">Cancelled</button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">No appointments scheduled for the selected day.</div>
        }
    </aside>
</div>

<div id="addAppointmentModal" class="calendar-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="addAppointmentTitle">
    <div class="calendar-modal">
        <div class="calendar-modal-header">
            <div>
                <h3 id="addAppointmentTitle">Add New Appointment</h3>
                <div class="muted">Staff-assisted booking aligned to the selected calendar day.</div>
            </div>
            <button type="button" class="btn small ghost" data-modal-close="addAppointmentModal">Close</button>
        </div>

        @using (Html.BeginForm("AddAppointment", "Calendar", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="calendar-modal-body">
                <input type="hidden" name="month" value="@Model.DisplayMonth.ToString("yyyy-MM-01")" />
                <input type="hidden" id="customerNameValue" name="customerName" value="" />

                <div class="calendar-form-grid">
                    <div class="calendar-field">
                        <label for="queueId">Queue</label>
                        <select id="queueId" name="queueId" required>
                            <option value="">Select a queue</option>
                            @foreach (var queue in Model.QueueOptions)
                            {
                                <option value="@queue.Value">@queue.Text</option>
                            }
                        </select>
                    </div>

                    <div class="calendar-field">
                        <label for="serviceId">Service</label>
                        <select id="serviceId" name="serviceId">
                            <option value="">Select service</option>
                        </select>
                    </div>

                    <div class="calendar-field">
                        <label for="contactType">Contact Type</label>
                        <select id="contactType" name="contactType">
                            <option value="">Select contact type</option>
                        </select>
                    </div>

                    <div class="calendar-field">
                        <label for="refValue">Reference</label>
                        <select id="refValue" name="refValue">
                            <option value="">Select reference</option>
                        </select>
                    </div>

                    <div class="calendar-field">
                        <label id="permitNumberLabel" for="permitNumber">Reference Value</label>
                        <input id="permitNumber" name="permitNumber" type="text" required placeholder="Enter reference value" />
                        <div id="permitNumberStatus" class="helper-text"></div>
                    </div>
                    <div class="calendar-field full is-hidden" id="addressFieldRow">
                        <label>Address</label>
                        <div class="calendar-form-grid">
                            <div class="calendar-field">
                                <label for="streetNumber">Street Number</label>
                                <input id="streetNumber" name="streetNumber" type="text" />
                            </div>
                            <div class="calendar-field">
                                <label for="streetName">Street Name</label>
                                <input id="streetName" name="streetName" type="text" />
                            </div>
                            <div class="calendar-field">
                                <label for="streetType">Street Type</label>
                                <input id="streetType" name="streetType" type="text" />
                            </div>
                        </div>
                    </div>

                    <div class="calendar-field">
                        <label for="email">Email</label>
                        <div class="lookup-input-wrap" id="emailWrap">
                            <input id="email" name="email" type="email" required />
                            <span class="lookup-spinner" aria-hidden="true"></span>
                        </div>
                        <div id="emailStatus" class="helper-text"></div>
                    </div>

                    <div class="calendar-field">
                        <label for="firstName">First Name</label>
                        <input id="firstName" name="firstName" type="text" required />
                    </div>

                    <div class="calendar-field">
                        <label for="lastName">Last Name</label>
                        <input id="lastName" name="lastName" type="text" required />
                    </div>

                    <div class="calendar-field">
                        <label for="phone">Phone</label>
                        <input id="phone" name="phone" type="tel" required />
                    </div>

                    <div class="calendar-field">
                        <label for="appointmentDate">Date</label>
                        <select id="appointmentDate" name="appointmentDate" required>
                            <option value="">Select date</option>
                        </select>
                    </div>

                    <div class="calendar-field">
                        <label for="startTime">Start Time</label>
                        <select id="startTime" name="startTime" required>
                            <option value="">Select time</option>
                        </select>
                    </div>

                    <div class="calendar-field full" id="meetingUrlField" style="display:none;">
                        <label for="meetingUrl">Meeting URL</label>
                        <input id="meetingUrl" name="meetingUrl" type="url" />
                    </div>

                    <div class="calendar-field full">
                        <label for="notes">Notes</label>
                        <textarea id="notes" name="notes" placeholder="Purpose, prep notes, or internal handoff context"></textarea>
                    </div>
                </div>
            </div>

            <div class="calendar-modal-footer">
                <button type="button" class="btn ghost" data-modal-close="addAppointmentModal">Cancel</button>
                <button type="submit" class="btn secondary">Save Appointment</button>
            </div>
        }
    </div>
</div>

<div id="addWalkinModal" class="calendar-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="addWalkinTitle">
    <div class="calendar-modal">
        <div class="calendar-modal-header">
            <div>
                <h3 id="addWalkinTitle">Add Walk-In</h3>
                <div class="muted">Create a same-day queue entry directly from the calendar.</div>
            </div>
            <button type="button" class="btn small ghost" data-modal-close="addWalkinModal">Close</button>
        </div>

        @using (Html.BeginForm("AddWalkin", "Calendar", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="calendar-modal-body">
                <input type="hidden" name="month" value="@Model.DisplayMonth.ToString("yyyy-MM-01")" />
                <input type="hidden" name="selectedDate" value="@modalDate.ToString("yyyy-MM-dd")" />
                <input type="hidden" id="walkinCustomerNameValue" name="customerName" value="" />

                <div class="calendar-form-grid">
                    <div class="calendar-field">
                        <label for="walkinQueueId">Queue</label>
                        <select id="walkinQueueId" name="queueId" required>
                            <option value="">Select a queue</option>
                            @foreach (var queue in Model.QueueOptions)
                            {
                                <option value="@queue.Value">@queue.Text</option>
                            }
                        </select>
                    </div>

                    <div class="calendar-field">
                        <label for="walkinServiceId">Service</label>
                        <select id="walkinServiceId" name="serviceId">
                            <option value="">Select service</option>
                        </select>
                    </div>

                    <div class="calendar-field">
                        <label for="walkinContactType">Contact Type</label>
                        <select id="walkinContactType" name="contactType">
                            <option value="">Select contact type</option>
